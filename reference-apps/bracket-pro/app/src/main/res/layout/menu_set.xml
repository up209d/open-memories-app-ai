<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:background="#88000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/menu_background"
        android:background="@drawable/p_16_dd_parts_43_set_background_menu3rdlayer"
        android:layout_width="518px"
        android:layout_height="480px"
        android:layout_marginLeft="62px"
        android:layout_marginTop="0px"
        android:scaleType="fitXY"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/menu_screen_title"
        android:layout_width="wrap_content"
        android:layout_height="46px"
        android:layout_marginLeft="13px"
        android:layout_marginTop="29px"
        android:layout_alignLeft="@+id/menu_background"
        android:layout_alignTop="@+id/menu_background"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <com.sony.imaging.app.base.menu.layout.ItemAlignedListView
        android:scrollbarSize="4px"
        android:scrollbarThumbHorizontal="@drawable/menu3rd_scrollbar"
        android:scrollbarThumbVertical="0x10811bb"
        android:scrollbarTrackHorizontal="@drawable/menu3rd_scrollbar"
        android:scrollbarTrackVertical="0x10811d6"
        android:scrollbarStyle="outsideInset"
        android:textColor="@color/RESID_FONTSTYLE_U_CMN"
        android:id="@+id/itemAlignedlistview"
        android:paddingRight="11px"
        android:scrollbars="vertical"
        android:fadingEdge="none"
        android:layout_width="489px"
        android:layout_height="302px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="95px"
        android:divider="0x10811af"
        android:dividerHeight="2px"
        android:layout_alignLeft="@+id/menu_background"
        android:layout_alignTop="@+id/menu_background"
        android:fadeScrollbars="false"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:layout_width="500px"
        android:layout_height="40px"
        android:layout_marginLeft="70px"
        android:layout_marginTop="413px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="0px"
        base:guide_text_marginTop="0px"
        base:guide_text_width="500px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/autofill_save_no"
        base:guide_text_emt="@android:string/httpErrorFailedSslHandshake"/>
</RelativeLayout>
