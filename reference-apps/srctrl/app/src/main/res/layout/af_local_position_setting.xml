<?xml version="1.0" encoding="utf-8"?>
<com.sony.imaging.app.base.shooting.widget.AFLocalPositionSetting xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:id="@+id/afFlexiblePositionSetting"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_alignParentLeft="true"
    android:layout_alignParentTop="true">
    <ImageView
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        android:src="@android:drawable/list_longpressed_holo_dark"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="left"
        android:layout_width="604px"
        android:layout_height="46px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="6px"
        android:text="@android:string/autofill_zip_4_re"
        style="@style/RESID_FONTSIZE_L_EDGE"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/af_local_footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:group="footer"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/work_mode_off_message"
        base:guide_text_emt="@android:string/httpErrorProxyAuth"/>
</com.sony.imaging.app.base.shooting.widget.AFLocalPositionSetting>
