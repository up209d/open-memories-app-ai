<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:orientation="horizontal"
        android:id="@+id/cwb_ee_linearLayout1"
        android:background="@android:drawable/list_longpressed_holo_dark"
        android:layout_width="640px"
        android:layout_height="60px"/>
    <ImageView
        android:id="@+id/header_icon_customwb"
        android:layout_width="52px"
        android:layout_height="40px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="8px"
        android:src="0x1080f51"/>
    <ImageView
        android:id="@+id/header_icon_set"
        android:layout_width="56px"
        android:layout_height="40px"
        android:layout_marginLeft="72px"
        android:layout_marginTop="8px"
        android:src="0x1080a9e"/>
    <com.sony.imaging.app.base.shooting.widget.SimulatingEERelativeLayout
        android:id="@+id/SimulatingEERelativeLayout_Fixation"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/cwb_circle"
            android:layout_width="64px"
            android:layout_height="64px"
            android:src="@android:drawable/ic_qs_dnd"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"/>
    </com.sony.imaging.app.base.shooting.widget.SimulatingEERelativeLayout>
    <ImageView
        android:id="@+id/cwb_ee_linearLayout2"
        android:background="0x10811c0"
        android:layout_width="600px"
        android:layout_height="106px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="303px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/cwbset_ee_message"
        android:layout_width="580px"
        android:layout_height="88px"
        android:layout_marginLeft="30px"
        android:layout_marginTop="312px"
        android:text="@android:string/permlab_expandStatusBar"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_OFF"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/date_picker_decrement_day_button"
        base:guide_text_emt="@android:string/hardware"/>
</RelativeLayout>
