<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:background="@drawable/p_16_dd_parts_oc_edit_background_full"
        android:layout_width="640px"
        android:layout_height="480px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"/>
    <com.sony.imaging.app.base.shooting.widget.AppIconView
        android:id="@+id/app_icon"
        android:layout_width="70px"
        android:layout_height="55px"
        android:layout_marginLeft="6px"
        android:layout_marginTop="0px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/theme_name"
        android:layout_width="422px"
        android:layout_height="46px"
        android:layout_marginLeft="80px"
        android:layout_marginTop="4px"
        android:text="@string/STRID_FUNC_SOUNDPHOTO_SOUND_RECORDING_SETTINGS"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/timing_title"
        android:layout_width="170px"
        android:layout_height="46px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="256px"
        android:text="@string/STRID_FUNC_SOUNDPHOTO_SHUTTER_TIMING"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <ImageView
        android:id="@+id/progress_gauge"
        android:layout_width="462px"
        android:layout_height="90px"
        android:layout_marginLeft="178px"
        android:layout_marginTop="250px"
        android:src="@drawable/p_16_dd_parts_soundphoto_gauge_backgoround"/>
    <ImageView
        android:layout_width="40px"
        android:layout_height="30px"
        android:layout_marginLeft="370px"
        android:layout_marginTop="304px"
        android:src="@drawable/p_16_dd_parts_soundphoto_gauge_backgoround_camera"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/timing_progress_bar"
        android:background="@drawable/state_streak_progress_selector"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="200px"
        android:layout_height="10px"
        android:layout_marginLeft="230px"
        android:layout_marginTop="277px"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/timing_precapture_disable"
        android:background="@drawable/p_16_dd_parts_soundphoto_bar_disable"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="200px"
        android:layout_height="10px"
        android:layout_marginLeft="230px"
        android:layout_marginTop="277px"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/timing_postcapture_disable"
        android:background="@drawable/p_16_dd_parts_soundphoto_bar_disable"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="200px"
        android:layout_height="10px"
        android:layout_marginLeft="230px"
        android:layout_marginTop="277px"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/progress_divider"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="wrap_content"
        android:layout_height="10px"
        android:layout_marginLeft="388px"
        android:layout_marginTop="277px"
        android:src="@drawable/p_16_dd_parts_soundphoto_leader_for_num"/>
    <ImageView
        android:id="@+id/precapture_time_bar"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="4px"
        android:layout_height="22px"
        android:layout_marginLeft="228px"
        android:layout_marginTop="252px"
        android:src="@drawable/p_16_dd_parts_soundphoto_leader_for_num"/>
    <ImageView
        android:id="@+id/postcapture_time_bar"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="4px"
        android:layout_height="22px"
        android:layout_marginLeft="428px"
        android:layout_marginTop="252px"
        android:src="@drawable/p_16_dd_parts_soundphoto_leader_for_num"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide_theme_option"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:group="footer"
        base:guide_text_style="@attr/footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="10px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@string/STRID_FUNC_SOUNDPHOTO_FOOTER_MENU"
        base:guide_text_emt="@string/STRID_FUNC_SOUNDPHOTO_FOOTER_MENU"/>
    <ImageView
        android:id="@+id/left_arrow"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="32px"
        android:layout_height="40px"
        android:layout_marginLeft="260px"
        android:layout_marginTop="138px"
        android:src="@drawable/p_16_dd_parts_soundphoto_arrow_left_disable"/>
    <ImageView
        android:id="@+id/right_arrow"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="32px"
        android:layout_height="40px"
        android:layout_marginLeft="526px"
        android:layout_marginTop="138px"
        android:src="@drawable/p_16_dd_parts_soundphoto_arrow_right_disable"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/duration_title"
        android:layout_width="170px"
        android:layout_height="46px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="136px"
        android:text="@string/STRID_FUNC_SOUNDPHOTO_SOUND_DURATION"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/precapture_time_value"
        android:layout_width="35px"
        android:layout_height="46px"
        android:layout_marginLeft="212px"
        android:layout_marginTop="205px"
        android:text="4"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/postcapture_time_value"
        android:layout_width="35px"
        android:layout_height="46px"
        android:layout_marginLeft="412px"
        android:layout_marginTop="205px"
        android:text="4"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/duration_text"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="220px"
        android:layout_height="46px"
        android:layout_marginLeft="299px"
        android:layout_marginTop="135px"
        android:text="@string/STRID_FUNC_SOUNDPHTO_TIME_10SEC"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
</RelativeLayout>
