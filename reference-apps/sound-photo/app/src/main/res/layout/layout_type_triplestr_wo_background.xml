<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="600px"
        android:layout_height="416px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="4px"
        android:src="@android:drawable/textfield_search_selected"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"/>
    <ImageView
        android:layout_width="560px"
        android:layout_height="130px"
        android:layout_marginLeft="40px"
        android:layout_marginTop="222px"
        android:src="@drawable/p_16_dd_parts_5w_cmn_exclusion_reason_message_bg"
        android:scaleType="fitXY"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/caution_text"
        android:layout_width="540px"
        android:layout_height="88px"
        android:layout_marginLeft="50px"
        android:layout_marginTop="94px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_OFF"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_INVALID_GUIDE"
        android:gravity="center"
        android:id="@+id/reason_title"
        android:layout_width="540px"
        android:layout_height="46px"
        android:layout_marginLeft="50px"
        android:layout_marginTop="234px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/reason_value"
        android:layout_width="540px"
        android:layout_height="42px"
        android:layout_marginLeft="50px"
        android:layout_marginTop="294px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_OFF"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="10px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/zen_mode_alarm"
        base:guide_text_emt="@android:string/zen_mode_alarm"/>
</RelativeLayout>
