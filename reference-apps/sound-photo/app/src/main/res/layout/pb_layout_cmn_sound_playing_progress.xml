<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/imageView"
        android:background="@drawable/playbackbar"
        android:layout_width="305px"
        android:layout_height="26px"
        android:layout_marginLeft="83px"
        android:layout_marginTop="342px"/>
    <SeekBar
        android:id="@+id/pb_progressBar"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:clickable="false"
        android:layout_width="301px"
        android:layout_height="22px"
        android:layout_marginLeft="85px"
        android:layout_marginTop="344px"
        android:max="10000"
        android:progressDrawable="@null"
        android:thumb="@drawable/playbackpos"
        android:thumbOffset="-1px"/>
    <ImageView
        android:id="@+id/play_pause"
        android:layout_width="57px"
        android:layout_height="44px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="333px"
        android:src="@drawable/playstatus_001"/>
    <TextView
        android:typeface="4"
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/pb_duration_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="409px"
        android:layout_marginTop="339px"
        android:text=""
        style="@style/RESID_FONTSIZE_STD_M_EDGE_ON"/>
</RelativeLayout>
