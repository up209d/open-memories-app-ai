<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/pb_parts_cmn_singlepb_yuv"
        layout="@layout/pb_parts_cmn_singlepb_yuv"/>
    <include
        android:id="@+id/pb_parts_cmn_singlepb_image_err"
        layout="@layout/pb_parts_cmn_singlepb_image_err"/>
    <include
        android:id="@+id/pb_parts_cmn_header"
        layout="@layout/pb_parts_cmn_header"/>
    <include
        android:id="@+id/pb_parts_cmn_header_contents_info"
        layout="@layout/pb_parts_cmn_header_contents_info"/>
    <include
        android:id="@+id/pb_layout_cmn_sound_playing_progress"
        layout="@layout/pb_layout_cmn_sound_playing_progress"/>
    <include
        android:id="@+id/pb_parts_cmn_layout_play_bottom_info"
        layout="@layout/sp_pb_parts_cmn_layout_play_bottom_info"/>
    <include
        android:id="@+id/pb_parts_cmn_layout_play_autoframing"
        layout="@layout/pb_parts_cmn_layout_play_autoframing"/>
    <include
        android:id="@+id/pb_parts_cmn_layout_play_error"
        layout="@layout/pb_parts_cmn_layout_play_error"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/cmn_footer_guide"
        android:background="@drawable/p_16_dd_parts_soundphoto_footer_translucent"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:group="cmn_footer"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"/>
</RelativeLayout>
