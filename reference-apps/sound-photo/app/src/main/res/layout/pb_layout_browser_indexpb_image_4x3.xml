<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/pb_parts_cmn_indexpb_4x3_grid"
        layout="@layout/pb_parts_cmn_indexpb_4x3_grid"/>
    <include
        android:id="@+id/pb_parts_cmn_header"
        layout="@layout/pb_parts_cmn_header"/>
    <include
        android:id="@+id/pb_parts_cmn_header_contents_info"
        layout="@layout/pb_parts_cmn_header_contents_info"/>
    <include
        android:id="@+id/pb_parts_cmn_indexpb_groupbar_header"
        layout="@layout/pb_parts_cmn_indexpb_groupbar_header"/>
    <include
        android:id="@+id/pb_parts_cmn_layout_play_dayinfo_bottom_nocard"
        layout="@layout/pb_parts_cmn_layout_play_dayinfo_bottom_nocard"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/cmn_footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:group="cmn_footer"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"/>
    <include
        android:id="@+id/pb_parts_cmn_layout_play_error"
        layout="@layout/pb_parts_cmn_layout_play_error"/>
</RelativeLayout>
