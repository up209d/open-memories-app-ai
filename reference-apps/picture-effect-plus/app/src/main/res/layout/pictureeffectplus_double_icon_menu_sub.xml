<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:background="#00000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/menu_screen_title"
        android:layout_width="422px"
        android:layout_height="46px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="4px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/menu_item"
        android:layout_width="484px"
        android:layout_height="46px"
        android:layout_marginLeft="68px"
        android:layout_marginTop="189px"
        style="@style/RESID_FONTSIZE_STD_L_EDGE_ON"/>
    <RelativeLayout
        android:id="@+id/two_plate_layout"
        android:background="@drawable/p_16_dd_parts_common_button_background"
        android:layout_width="196px"
        android:layout_height="66px"
        android:layout_marginLeft="224px"
        android:layout_marginTop="360px">
        <ImageView
            android:id="@+id/first_color_focus_plate"
            android:layout_width="96px"
            android:layout_height="66px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/first_color_plate"
            android:layout_width="96px"
            android:layout_height="72px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/two_plate_divider"
            android:layout_width="2px"
            android:layout_height="72px"
            android:layout_marginLeft="96px"
            android:layout_marginTop="0px"
            android:src="@drawable/p_16_dd_parts_pe_parameter_separater"/>
        <ImageView
            android:id="@+id/second_color_focus_plate"
            android:layout_width="96px"
            android:layout_height="72px"
            android:layout_marginLeft="98px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/second_color_plate"
            android:layout_width="96px"
            android:layout_height="66px"
            android:layout_marginLeft="98px"
            android:layout_marginTop="0px"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/four_plate_layout"
        android:background="@drawable/p_16_dd_parts_common_button_background"
        android:layout_width="192px"
        android:layout_height="66px"
        android:layout_marginLeft="118px"
        android:layout_marginTop="360px">
        <ImageView
            android:id="@+id/first_color_four_focus_plate"
            android:layout_width="95px"
            android:layout_height="66px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/first_color_four_plate"
            android:layout_width="95px"
            android:layout_height="66px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/four_plate_first_divider"
            android:layout_width="2px"
            android:layout_height="66px"
            android:layout_marginLeft="95px"
            android:layout_marginTop="0px"
            android:src="@drawable/p_16_dd_parts_pe_parameter_separater"/>
        <ImageView
            android:id="@+id/second_color_four_focus_plate"
            android:layout_width="95px"
            android:layout_height="66px"
            android:layout_marginLeft="97px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/second_color_four_plate"
            android:layout_width="95px"
            android:layout_height="66px"
            android:layout_marginLeft="97px"
            android:layout_marginTop="0px"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/four_plate_layout_second_part"
        android:background="@drawable/p_16_dd_parts_common_button_background"
        android:layout_width="192px"
        android:layout_height="66px"
        android:layout_marginLeft="315px"
        android:layout_marginTop="360px">
        <ImageView
            android:id="@+id/first_color_gauge_bar_four_focus_plate"
            android:layout_width="95px"
            android:layout_height="66px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/first_color_gauge_bar_four_plate"
            android:layout_width="95px"
            android:layout_height="66px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/four_plate_third_divider"
            android:layout_width="2px"
            android:layout_height="66px"
            android:layout_marginLeft="95px"
            android:layout_marginTop="0px"
            android:src="@drawable/p_16_dd_parts_pe_parameter_separater"/>
        <ImageView
            android:id="@+id/second_color_gauge_bar_four_focus_plate"
            android:layout_width="95px"
            android:layout_height="66px"
            android:layout_marginLeft="97px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/second_color_gauge_bar_four_plate"
            android:layout_width="95px"
            android:layout_height="66px"
            android:layout_marginLeft="97px"
            android:layout_marginTop="0px"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/vsb_src"
        android:background="@drawable/p_16_dd_parts_common_gauge_scale"
        android:layout_width="72px"
        android:layout_height="226px"
        android:layout_marginLeft="568px"
        android:layout_marginTop="88px"
        android:src="@drawable/p_16_dd_parts_pe_gauge_background"/>
    <com.sony.imaging.app.pictureeffectplus.shooting.widget.VerticalSeekBar
        android:id="@+id/vertical_Seekbar"
        android:layout_width="72px"
        android:layout_height="226px"
        android:layout_marginLeft="588px"
        android:layout_marginTop="88px"
        android:progressDrawable="@null"
        android:thumb="@drawable/p_16_dd_parts_common_gauge_scale_circle"
        android:thumbOffset="0px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="right"
        android:id="@+id/vertical_sb_progresstext"
        android:layout_width="69px"
        android:layout_height="46px"
        android:layout_marginLeft="511px"
        android:layout_marginTop="178px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="right"
        android:id="@+id/gauge_low"
        android:layout_width="178px"
        android:layout_height="38px"
        android:layout_marginLeft="442px"
        android:layout_marginTop="314px"
        android:text="@string/STRID_FUNC_MLTPARTCLR_SATULATION_LESS"
        style="@style/RESID_FONTSIZE_BIG_S_EDGE_ON"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="top|right"
        android:id="@+id/gauge_high"
        android:layout_width="178px"
        android:layout_height="38px"
        android:layout_marginLeft="442px"
        android:layout_marginTop="50px"
        android:text="@string/STRID_FUNC_MLTPARTCLR_SATULATION_MORE"
        style="@style/RESID_FONTSIZE_BIG_S_EDGE_ON"/>
    <com.sony.imaging.app.pictureeffectplus.menu.layout.VerticalScrollView
        android:id="@+id/verticalScrollView"
        android:scrollbars="none"
        android:fadingEdge="none"
        android:layout_width="94px"
        android:layout_height="360px"
        android:layout_marginLeft="544px"
        android:layout_marginTop="30px"
        android:cacheColorHint="#00000000"
        android:divider="#00000000"
        android:smoothScrollbar="true"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/autofill_phone_suffix_separator_re"
        base:guide_text_emt="@android:string/httpErrorAuth"/>
</RelativeLayout>
