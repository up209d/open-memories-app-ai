<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto">
    <com.sony.imaging.app.base.shooting.widget.VisibilityChangeZoombarGroup
        android:id="@+id/error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        base:zoombargroup="error">
        <com.sony.imaging.app.base.common.widget.SteadyShotErrorIcon
            android:id="@+id/camera_shake_error"
            android:layout_width="76px"
            android:layout_height="36px"
            android:layout_marginLeft="340px"
            android:layout_marginTop="79px"/>
        <com.sony.imaging.app.util.RelativeLayoutGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            base:group="AbnormalTemperature"
            base:watch_target="@+id/abnormal_icon">
            <com.sony.imaging.app.base.common.widget.AbnormalTemperatureIcon
                android:id="@+id/abnormal_icon"
                android:layout_width="34px"
                android:layout_height="36px"
                android:layout_marginLeft="304px"
                android:layout_marginTop="79px"
                android:scaleType="center"
                base:heat="0x1080d13"/>
        </com.sony.imaging.app.util.RelativeLayoutGroup>
    </com.sony.imaging.app.base.shooting.widget.VisibilityChangeZoombarGroup>
    <com.sony.imaging.app.util.RelativeLayoutGroup
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        base:group="Database"
        base:watch_target="@+id/DatabaseIcon">
        <com.sony.imaging.app.base.common.widget.DatabaseIcon
            android:id="@+id/DatabaseIcon"
            android:layout_width="60px"
            android:layout_height="36px"
            android:layout_marginLeft="242px"
            android:layout_marginTop="79px"
            android:scaleType="center"
            base:database_error="@android:drawable/sym_keyboard_shift"
            base:database_full="0x10809fa"/>
    </com.sony.imaging.app.util.RelativeLayoutGroup>
    <com.sony.imaging.app.util.GroupingLayout
        android:id="@+id/FinderErrors"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        base:priority_id="@+id/FinderErrorIcon">
        <com.sony.imaging.app.base.common.widget.FinderErrorIcon
            android:id="@+id/FinderErrorIcon"
            android:layout_width="52px"
            android:layout_height="36px"
            android:layout_marginLeft="188px"
            android:layout_marginTop="79px"
            android:scaleType="center"
            base:finder_error="@android:drawable/jog_tab_bar_left_generic"/>
        <com.sony.imaging.app.base.common.widget.AbnormalTemperatureFinderIcon
            android:layout_width="52px"
            android:layout_height="36px"
            android:layout_marginLeft="188px"
            android:layout_marginTop="79px"
            android:scaleType="center"
            base:heat_finder="@drawable/p_panel_heatfinder"
            base:heat_finder_down="@drawable/p_panel_heatfinder_down"/>
    </com.sony.imaging.app.util.GroupingLayout>
    <com.sony.imaging.app.base.shooting.widget.VisibilityChangeZoombarGroup
        android:id="@+id/zoom_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        base:zoombargroup="zoom_bar">
        <com.sony.imaging.app.base.shooting.widget.ZoomBar
            android:id="@+id/zoomBar"
            android:layout_width="216px"
            android:layout_height="68px"
            android:layout_marginLeft="332px"
            android:layout_marginTop="47px"
            base:zoom_non_divided_bar="@android:drawable/progress_horizontal_holo_light"
            base:zoom_divided_bar="0x10810c3"
            base:zoom_position="@android:drawable/ic_voice_search_api_material"
            base:zoom_position_margin="22px">
            <TextView
                android:typeface="4"
                android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
                android:gravity="center"
                android:id="@+id/focalLength"
                android:layout_width="90px"
                android:layout_height="36px"
                android:layout_alignParentLeft="true"
                android:layout_alignParentBottom="true"
                style="@style/RESID_FONTSIZE_STD_M_EDGE_ON"/>
        </com.sony.imaging.app.base.shooting.widget.ZoomBar>
    </com.sony.imaging.app.base.shooting.widget.VisibilityChangeZoombarGroup>
    <com.sony.imaging.app.base.shooting.widget.DigitalZoomInfo
        android:id="@+id/DigitalZoomInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        base:zoom_smart="0x10809d4"
        base:zoom_clear="@android:drawable/seekbar_tick_mark_material"
        base:zoom_precision="@android:drawable/ic_clear_search_api_holo_light">
        <TextView
            android:typeface="4"
            android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
            android:gravity="center"
            android:id="@+id/magnification"
            android:layout_width="65px"
            android:layout_height="36px"
            android:layout_marginLeft="470px"
            android:layout_marginTop="79px"
            style="@style/RESID_FONTSIZE_STD_M_EDGE_ON"/>
        <ImageView
            android:id="@+id/zoom_icon"
            android:layout_width="48px"
            android:layout_height="36px"
            android:layout_marginLeft="422px"
            android:layout_marginTop="79px"
            android:scaleType="center"/>
    </com.sony.imaging.app.base.shooting.widget.DigitalZoomInfo>
</merge>
