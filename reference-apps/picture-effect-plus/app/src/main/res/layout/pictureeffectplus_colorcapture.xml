<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/cwb_ee_linearLayout1"
        android:background="@android:drawable/ic_work_apps_off"
        android:layout_width="540px"
        android:layout_height="46px">
        <ImageView
            android:id="@+id/header_icon_customwbset"
            android:layout_width="99px"
            android:layout_height="46px"
            android:src="@drawable/p_16_dd_parts_pe_menu_capture_lcd_icon_part_color_plus_custom_set"/>
    </LinearLayout>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/screen_title"
        android:layout_width="604px"
        android:layout_height="46px"
        android:layout_marginLeft="80px"
        android:layout_marginTop="4px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <ImageView
        android:id="@+id/cwb_circle"
        android:layout_width="64px"
        android:layout_height="64px"
        android:layout_marginTop="116px"
        android:src="@android:drawable/ic_qs_dnd"
        android:layout_centerHorizontal="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/cwb_ee_linearLayout2"
        android:background="0x108137c"
        android:layout_width="600px"
        android:layout_height="198px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="211px">
        <TextView
            android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
            android:id="@+id/cwbset_ee_message"
            android:layout_width="580px"
            android:layout_height="180px"
            android:layout_marginLeft="10px"
            android:layout_marginTop="9px"
            android:text="@string/STRID_FUNC_MLTPARTCLR_CSTMSET_GUIDE"
            style="@style/RESID_FONTSIZE_STD_M_EDGE_ON"/>
    </LinearLayout>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/autofill_phone_suffix_separator_re"
        base:guide_text_emt="@android:string/httpErrorAuth"/>
</RelativeLayout>
