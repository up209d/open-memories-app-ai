<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto">
    <com.sony.imaging.app.base.shooting.widget.MiniatureEffectView
        android:id="@+id/MiniatureEffectView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.sony.imaging.app.base.shooting.widget.SimulatingEERelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.sony.imaging.app.base.shooting.widget.GridLine
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </com.sony.imaging.app.base.shooting.widget.SimulatingEERelativeLayout>
    <com.sony.imaging.app.base.common.widget.SwitchLayoutGroup
        android:id="@+id/heder_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        base:min="1"
        base:max="16">
        <com.sony.imaging.app.base.shooting.widget.SimulatingEERelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.sony.imaging.app.base.shooting.widget.MeteringModeCenterCircleView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                base:circle="@android:drawable/ic_qs_dnd"/>
        </com.sony.imaging.app.base.shooting.widget.SimulatingEERelativeLayout>
    </com.sony.imaging.app.base.common.widget.SwitchLayoutGroup>
    <com.sony.imaging.app.base.common.widget.SwitchLayoutGroup
        android:id="@+id/heder_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        base:min="17">
        <com.sony.imaging.app.base.shooting.widget.MeteringModeCircleView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            base:circle="@android:drawable/ic_qs_dnd"
            base:circle_3x="@android:drawable/spinner_background_holo_dark"/>
    </com.sony.imaging.app.base.common.widget.SwitchLayoutGroup>
    <com.sony.imaging.app.base.shooting.widget.MovieRecStateIcon
        android:gravity="right"
        android:layout_width="115px"
        android:layout_height="32px"
        android:layout_marginLeft="73px"
        android:layout_marginTop="393px"
        base:text_rec="@android:string/mmcc_authentication_reject"
        base:text_standby="0x1040bd4"/>
    <com.sony.imaging.app.base.shooting.widget.MovieRecTimeIcon
        android:typeface="4"
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:layout_width="100px"
        android:layout_height="32px"
        android:layout_marginLeft="188px"
        android:layout_marginTop="393px"
        style="@style/RESID_FONTSIZE_SP_REC_LV_MOVIE_TIME"/>
</merge>
