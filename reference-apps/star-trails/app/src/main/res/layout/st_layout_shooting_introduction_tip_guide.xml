<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        android:src="@android:drawable/list_longpressed_holo_dark"/>
    <ImageView
        android:id="@+id/appicon"
        android:layout_width="60px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        android:src="@drawable/p_16_aa_parts_strl_appicon"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/menu_screen_title"
        android:layout_width="484px"
        android:layout_height="456px"
        android:layout_marginLeft="68px"
        android:layout_marginTop="40px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="640px"
        android:layout_height="360px"
        android:layout_marginTop="60px"
        android:fadeScrollbars="false">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.sony.imaging.app.startrails.shooting.widget.STImageView
                android:id="@+id/first_image"
                android:layout_width="150px"
                android:layout_height="150px"
                android:layout_marginLeft="53px"
                android:layout_marginTop="14px"/>
            <com.sony.imaging.app.startrails.shooting.widget.STImageView
                android:id="@+id/second_image"
                android:layout_width="150px"
                android:layout_height="150px"
                android:layout_marginLeft="219px"
                android:layout_marginTop="14px"/>
            <com.sony.imaging.app.startrails.shooting.widget.STImageView
                android:id="@+id/multiple_exposure_image"
                android:layout_width="150px"
                android:layout_height="150px"
                android:layout_marginLeft="423px"
                android:layout_marginTop="14px"/>
            <TextView
                android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
                android:id="@+id/first_image_text"
                android:layout_width="24px"
                android:layout_height="40px"
                android:layout_marginLeft="57px"
                android:layout_marginTop="189px"
                android:text="@string/STRID_FUNC_STRLS_INTRODUCTION_GUIDE"
                style="@style/RESID_FONTSIZE_STD_L_EDGE_OFF"/>
            <TextView
                android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
                android:id="@+id/first_image_detail"
                android:layout_width="484px"
                android:layout_height="112px"
                android:layout_marginLeft="85px"
                android:layout_marginTop="189px"
                android:text="@string/STRID_FUNC_STRS_MENU_ITEMS_SHOOTING_TIPS"
                style="@style/RESID_FONTSIZE_STD_L_EDGE_OFF"/>
            <TextView
                android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
                android:id="@+id/second_image_text"
                android:layout_width="24px"
                android:layout_height="40px"
                android:layout_marginLeft="57px"
                android:layout_marginTop="301px"
                android:text="@string/STRID_FUNC_STRS_MENU_ITEMS_SHOOTING_TIPS"
                style="@style/RESID_FONTSIZE_STD_L_EDGE_OFF"/>
            <TextView
                android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
                android:id="@+id/second_image_detail"
                android:layout_width="484px"
                android:layout_height="112px"
                android:layout_marginLeft="85px"
                android:layout_marginTop="301px"
                style="@style/RESID_FONTSIZE_STD_L_EDGE_OFF"/>
        </RelativeLayout>
    </ScrollView>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/years"
        base:guide_text_emt="@android:string/years"/>
</RelativeLayout>
