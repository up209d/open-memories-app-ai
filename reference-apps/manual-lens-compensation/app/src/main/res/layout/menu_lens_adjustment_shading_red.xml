<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.sony.imaging.app.manuallenscompensation.widget.OCGridLine
        android:id="@+id/mlcgridview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ImageView
        android:id="@+id/vsb_plus"
        android:background="@drawable/p_16_dd_parts_oc_adjust_common_gauge_scale_plus"
        android:layout_width="32px"
        android:layout_height="32px"
        android:layout_marginLeft="588px"
        android:layout_marginTop="50px"/>
    <ImageView
        android:id="@+id/vsb_minus"
        android:background="@drawable/p_16_dd_parts_oc_adjust_common_gauge_scale_minus"
        android:layout_width="32px"
        android:layout_height="32px"
        android:layout_marginLeft="588px"
        android:layout_marginTop="320px"/>
    <ImageView
        android:id="@+id/ImageStyle"
        android:layout_width="78px"
        android:layout_height="80px"
        android:layout_marginLeft="9px"
        android:layout_marginTop="52px"/>
    <com.sony.imaging.app.base.menu.layout.SubMenuView
        android:id="@+id/ListView"
        android:scrollbars="none"
        android:fadingEdge="none"
        android:layout_width="100px"
        android:layout_height="480px"
        android:layout_marginLeft="540px"
        android:layout_marginTop="0px"
        android:cacheColorHint="#00000000"
        android:divider="#00000000"
        android:smoothScrollbar="true"/>
    <com.sony.imaging.app.base.menu.layout.SubMenuArea
        android:id="@+id/FocusSubMenu"
        android:layout_width="100px"
        android:layout_height="480px"
        android:layout_marginLeft="540px"
        android:layout_marginTop="0px"/>
    <ImageView
        android:id="@+id/leftArrow"
        android:layout_width="21px"
        android:layout_height="38px"
        android:layout_marginLeft="153px"
        android:layout_marginTop="374px"
        android:src="@drawable/p_16_dd_parts_oc_left_arrow"/>
    <ImageView
        android:id="@+id/rightArrow"
        android:layout_width="21px"
        android:layout_height="38px"
        android:layout_marginLeft="466px"
        android:layout_marginTop="376px"
        android:src="@drawable/p_16_dd_parts_oc_right_arrow"/>
    <RelativeLayout
        android:id="@+id/iconBase"
        android:background="@drawable/p_16_dd_parts_oc_adjust_button_background"
        android:layout_width="216px"
        android:layout_height="66px"
        android:layout_marginLeft="162px"
        android:layout_marginTop="414px"/>
    <ImageView
        android:id="@+id/optionLeft"
        android:layout_width="72px"
        android:layout_height="66px"
        android:layout_marginLeft="162px"
        android:layout_marginTop="414px"/>
    <ImageView
        android:id="@+id/optionLeftImage"
        android:layout_width="72px"
        android:layout_height="66px"
        android:layout_marginLeft="162px"
        android:layout_marginTop="414px"/>
    <RelativeLayout
        android:id="@+id/mRLayout"
        android:layout_width="144px"
        android:layout_height="66px"
        android:layout_marginLeft="234px"
        android:layout_marginTop="0px">
        <ImageView
            android:id="@+id/optionCenter"
            android:layout_width="72px"
            android:layout_height="66px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:id="@+id/optionCenterImage"
            android:layout_width="72px"
            android:layout_height="66px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:gravity="right"
            android:id="@+id/optionRight"
            android:layout_width="72px"
            android:layout_height="66px"
            android:layout_marginLeft="72px"
            android:layout_marginTop="0px"/>
        <ImageView
            android:gravity="right"
            android:id="@+id/optionRightImage"
            android:layout_width="72px"
            android:layout_height="66px"
            android:layout_marginLeft="72px"
            android:layout_marginTop="0px"/>
    </RelativeLayout>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/menu_screen_title"
        android:layout_width="484px"
        android:layout_height="46px"
        android:layout_marginLeft="9px"
        android:layout_marginTop="3px"
        android:text="@string/STRID_FUNC_OPTICAL_COMPENSATION_PERIPHERAL_SHADING"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <com.sony.imaging.app.base.shooting.widget.CompensationWheelAndInfoView xmlns:base="http://schemas.android.com/apk/res/auto"
        android:id="@+id/CompensationWheelAndInfoView"
        android:layout_width="198px"
        android:layout_height="344px"
        android:layout_marginLeft="432px"
        android:layout_marginTop="68px"/>
    <TextView
        android:gravity="center"
        android:id="@+id/vertical_sb_progresstext"
        android:layout_width="69px"
        android:layout_height="46px"
        android:layout_marginLeft="511px"
        android:layout_marginTop="178px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <ImageView
        android:id="@+id/vsb_src"
        android:background="@drawable/p_16_dd_parts_oc_adjust_shading_red_gauge_scale"
        android:layout_width="72px"
        android:layout_height="226px"
        android:layout_marginLeft="568px"
        android:layout_marginTop="88px"
        android:src="@drawable/p_16_dd_parts_oc_adjust_shading_red_gauge_background"
        android:scaleType="fitXY"/>
    <com.sony.imaging.app.manuallenscompensation.widget.VerticalSeekBar
        android:id="@+id/vertical_Seekbar"
        android:layout_width="72px"
        android:layout_height="226px"
        android:layout_marginLeft="588px"
        android:layout_marginTop="88px"
        android:thumb="@drawable/p_16_dd_parts_oc_adjust_common_gauge_scale_circle"
        android:thumbOffset="0px"/>
    <include
        android:id="@+id/pb_parts_cmn_deletor_multiple_footer_guide_count"
        layout="@layout/pb_parts_cmn_deletor_multiple_footer_guide_count"/>
</RelativeLayout>
