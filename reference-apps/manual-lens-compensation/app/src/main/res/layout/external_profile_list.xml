<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lens_list_screen"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/header"
        android:background="@drawable/p_16_dd_parts_oc_list_header"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"/>
    <ImageView
        android:id="@+id/app_icon"
        android:layout_width="70px"
        android:layout_height="55px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        android:src="@drawable/p_16_dd_parts_oc_appicon"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center_vertical"
        android:id="@+id/title"
        android:layout_width="484px"
        android:layout_height="46px"
        android:layout_marginLeft="70px"
        android:layout_marginTop="5px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <ImageView
        android:id="@+id/middle_part_create"
        android:background="#000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="0px"
        android:layout_marginTop="54px"/>
    <ImageView
        android:id="@+id/middle_part"
        android:background="#000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="0px"
        android:layout_marginTop="54px"/>
    <ListView
        android:id="@+id/list_view"
        android:paddingLeft="5px"
        android:paddingRight="5px"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="10px"
        android:layout_marginTop="82px"
        android:layout_marginRight="10px"
        android:listSelector="@android:color/transparent"
        android:cacheColorHint="#00000000"
        android:divider="@android:color/transparent"
        android:dividerHeight="10px"
        style="@style/listview_scrollbar"/>
</RelativeLayout>
