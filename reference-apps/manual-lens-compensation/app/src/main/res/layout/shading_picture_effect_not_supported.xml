<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_MENU_ITEM_DISABLE"
        android:id="@+id/shooting_Shading_pe"
        android:layout_width="348px"
        android:layout_height="46px"
        android:layout_marginLeft="22px"
        android:layout_marginTop="114px"
        android:text="@string/STRID_FUNC_OPTICAL_COMPENSATION_PERIPHERAL_SHADING"
        style="@style/RESID_FONTSIZE_STD_L_EDGE_ON"/>
    <com.sony.imaging.app.manuallenscompensation.widget.LevelGauge
        android:id="@+id/shading_white_pe"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="154px"
        android:layout_height="20px"
        android:layout_marginLeft="444px"
        android:layout_marginTop="108px"
        android:max="32"
        android:progressDrawable="@drawable/p_16_dd_parts_oc_shading_bright_gauge_disable"
        android:thumb="@drawable/p_16_dd_parts_oc_shading_bright_circle_disable"
        android:thumbOffset="0px"/>
    <com.sony.imaging.app.manuallenscompensation.widget.LevelGauge
        android:id="@+id/shading_red_pe"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="154px"
        android:layout_height="20px"
        android:layout_marginLeft="444px"
        android:layout_marginTop="128px"
        android:max="32"
        android:progressDrawable="@drawable/p_16_dd_parts_oc_shading_red_gauge_disable"
        android:thumb="@drawable/p_16_dd_parts_oc_shading_red_circle_disable"
        android:thumbOffset="0px"/>
    <com.sony.imaging.app.manuallenscompensation.widget.LevelGauge
        android:id="@+id/shading_blue_pe"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="154px"
        android:layout_height="20px"
        android:layout_marginLeft="444px"
        android:layout_marginTop="148px"
        android:max="32"
        android:progressDrawable="@drawable/p_16_dd_parts_oc_shading_blue_gauge_disable"
        android:thumb="@drawable/p_16_dd_parts_oc_shading_blue_circle_disable"
        android:thumbOffset="0px"/>
    <ImageView
        android:id="@+id/minus_level1"
        android:layout_width="24px"
        android:layout_height="24px"
        android:layout_marginLeft="420px"
        android:layout_marginTop="125px"
        android:src="@drawable/p_16_dd_parts_oc_minus_icon"/>
    <ImageView
        android:id="@+id/plus_level1"
        android:layout_width="24px"
        android:layout_height="24px"
        android:layout_marginLeft="598px"
        android:layout_marginTop="125px"
        android:src="@drawable/p_16_dd_parts_oc_plus_icon"/>
</RelativeLayout>
