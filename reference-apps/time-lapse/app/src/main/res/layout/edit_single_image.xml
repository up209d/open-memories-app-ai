<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/header"
        android:background="@android:drawable/list_longpressed_holo_dark"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"/>
    <com.sony.imaging.app.base.shooting.widget.AppIconView
        android:id="@+id/app_icon"
        android:layout_width="70px"
        android:layout_height="55px"
        android:layout_marginLeft="6px"
        android:layout_marginTop="0px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/theme_name"
        android:layout_width="422px"
        android:layout_height="46px"
        android:layout_marginLeft="80px"
        android:layout_marginTop="4px"
        android:text="Standard"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <com.sony.imaging.app.base.common.widget.BatteryIcon
        android:id="@+id/BatteryIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="590px"
        android:layout_marginTop="1px"
        android:src="@drawable/icon_battery"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:group="confirm_footer"
        base:guide_text_style="@attr/footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="10px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@string/STRID_FUNC_TIMELAPSE_EDIT_INFO_FOOTER_GUIDE"
        base:guide_text_emt="@string/STRID_FUNC_TIMELAPSE_EDIT_INFO_FOOTER_GUIDE_SK"/>
    <include
        android:id="@+id/pb_parts_cmn_singlepb_yuv"
        layout="@layout/pb_parts_cmn_singlepb_yuv"/>
    <include
        android:id="@+id/as_crop_view"
        layout="@layout/as_crop_view"/>
    <include
        android:id="@+id/pb_parts_cmn_singlepb_image_err"
        layout="@layout/pb_parts_cmn_singlepb_image_err"/>
    <include
        android:id="@+id/pb_parts_cmn_header_noinfo"
        layout="@layout/pb_parts_cmn_header_noinfo"/>
    <include
        android:id="@+id/pb_parts_cmn_toucharea"
        layout="@layout/pb_parts_cmn_toucharea"/>
    <TextView
        android:textColor="#5599dd"
        android:id="@+id/edit_start_flag_name"
        android:layout_width="228px"
        android:layout_height="42px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="62px"
        android:text="@string/STRID_FUNC_TIMELAPSE_EFFECT_START_FRAME"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <TextView
        android:textColor="#cc1166"
        android:id="@+id/edit_end_flag_name"
        android:layout_width="228px"
        android:layout_height="42px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="111px"
        android:text="@string/STRID_FUNC_TIMELAPSE_EFFECT_END_FRAME"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <com.sony.imaging.app.timelapse.shooting.widget.TimelapseTextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/previewBtn"
        android:background="@drawable/state_btn_custom"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="180px"
        android:layout_height="48px"
        android:layout_marginLeft="451px"
        android:layout_marginTop="303px"
        android:text="PREVIEW"
        android:lineSpacingExtra="0px"
        style="@style/RESID_FONTSIZE_STD_M_EDGE_ON"/>
    <com.sony.imaging.app.timelapse.shooting.widget.TimelapseTextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/saveBtn"
        android:background="@drawable/state_btn_custom"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="180px"
        android:layout_height="48px"
        android:layout_marginLeft="451px"
        android:layout_marginTop="360px"
        android:text="SAVE"
        android:lineSpacingExtra="0px"
        style="@style/RESID_FONTSIZE_STD_M_EDGE_ON"/>
    <com.sony.imaging.app.timelapse.shooting.widget.TimelapseImageView
        android:id="@+id/recording_mode"
        android:layout_width="102px"
        android:layout_height="48px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="326px"
        android:src="@drawable/p_16_dd_parts_tm_recordingmode_movie24p_menu_normal"/>
    <com.sony.imaging.app.timelapse.shooting.widget.TimelapseImageView
        android:id="@+id/fader"
        android:layout_width="128px"
        android:layout_height="48px"
        android:layout_marginLeft="118px"
        android:layout_marginTop="326px"
        android:src="@drawable/p_16_dd_parts_tm_fade_on_normal"/>
    <com.sony.imaging.app.timelapse.shooting.widget.TimelapseImageView
        android:id="@+id/moviesize"
        android:layout_width="128px"
        android:layout_height="48px"
        android:layout_marginLeft="254px"
        android:layout_marginTop="326px"
        android:src="@drawable/p_16_dd_parts_tm_1920x1080_normal"/>
    <com.sony.imaging.app.timelapse.shooting.widget.TimelapseImageView
        android:id="@+id/shooting_num_icon"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="48px"
        android:layout_height="48px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="374px"
        android:src="@drawable/p_16_dd_parts_tm_shootingnum_icon_small_nomal"/>
    <TextView
        android:typeface="4"
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/shooting_num_value"
        android:layout_width="66px"
        android:layout_height="42px"
        android:layout_marginLeft="59px"
        android:layout_marginTop="377px"
        android:text="780"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <com.sony.imaging.app.timelapse.shooting.widget.TimelapseImageView
        android:id="@+id/playback_image_view"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="48px"
        android:layout_height="48px"
        android:layout_marginLeft="130px"
        android:layout_marginTop="374px"
        android:src="@drawable/p_16_dd_parts_tm_playbacktime_icon_small_nomal"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/playback_value"
        android:layout_width="207px"
        android:layout_height="42px"
        android:layout_marginLeft="181px"
        android:layout_marginTop="377px"
        android:text="41 sec"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
</RelativeLayout>
