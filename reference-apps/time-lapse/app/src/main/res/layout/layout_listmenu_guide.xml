<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/guide"
    android:background="@android:color/transparent"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@drawable/s_16_dd_parts_guide_base_divi9"
        android:padding="0px"
        android:layout_width="540px"
        android:layout_height="378px"
        android:layout_marginLeft="50px"
        android:layout_marginTop="51px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true">
        <TextView
            android:textColor="@color/RESID_FONTSTYLE_ERROR_NO_SKIN"
            android:id="@+id/guide_title"
            android:layout_width="484px"
            android:layout_height="40px"
            android:layout_marginLeft="28px"
            android:layout_marginTop="37px"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            style="@style/RESID_FONTSIZE_L"/>
        <TextView
            android:gravity="top"
            android:layout_gravity="top"
            android:id="@+id/guide_contents"
            android:layout_width="484px"
            android:layout_height="210px"
            android:layout_marginLeft="28px"
            android:layout_marginTop="85px"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            style="@style/RESID_FONTSIZE_M"/>
        <ImageView
            android:background="@drawable/s_16_dd_parts_guide_base_footer_divi"
            android:layout_width="540px"
            android:layout_height="75px"
            android:layout_marginLeft="0px"
            android:layout_marginTop="303px"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"/>
        <TextView
            android:id="@+id/guide_footer"
            android:layout_width="484px"
            android:layout_height="36px"
            android:layout_marginLeft="28px"
            android:layout_marginTop="308px"
            android:text="0x1040999"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            style="@style/RESID_FONTSIZE_M"/>
    </RelativeLayout>
    <View
        android:id="@+id/guide_wrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"/>
</RelativeLayout>
