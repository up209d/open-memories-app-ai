<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.sony.imaging.app.base.shooting.widget.SimulatingEERelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.sony.imaging.app.base.shooting.widget.FocusMagnificationGuide_1_0
            android:id="@+id/magnification_position_view_1_0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </com.sony.imaging.app.base.shooting.widget.SimulatingEERelativeLayout>
    <ImageView
        android:id="@+id/up_arrow"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="303px"
        android:layout_marginTop="2px"
        android:src="0x1080e0a"/>
    <ImageView
        android:id="@+id/down_arrow"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="303px"
        android:layout_marginTop="410px"
        android:src="0x1080e95"/>
    <ImageView
        android:id="@+id/left_arrow"
        android:layout_width="21px"
        android:layout_height="38px"
        android:layout_marginLeft="2px"
        android:layout_marginTop="195px"
        android:src="0x108106f"/>
    <ImageView
        android:id="@+id/right_arrow"
        android:layout_width="21px"
        android:layout_height="38px"
        android:layout_marginLeft="617px"
        android:layout_marginTop="195px"
        android:src="@android:drawable/ic_clear_material"/>
    <include
        android:id="@+id/shooting_parts_sid_ee_touch_area"
        layout="@layout/shooting_parts_sid_ee_touch_area"/>
    <ImageView
        android:layout_width="40px"
        android:layout_height="36px"
        android:layout_marginLeft="2px"
        android:layout_marginTop="1px"
        android:src="@android:drawable/quickactions_arrowup_left_holo_dark"/>
    <com.sony.imaging.app.base.shooting.widget.MfAssistMagnificationRatio
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/magnification_ratio_view"
        android:background="@android:color/transparent"
        android:layout_width="110px"
        android:layout_height="36px"
        android:layout_marginLeft="42px"
        android:layout_marginTop="0px"
        style="@style/RESID_FONTSIZE_STD_M_EDGE_ON"/>
    <ImageView
        android:layout_width="96px"
        android:layout_height="48px"
        android:layout_marginLeft="439px"
        android:layout_marginTop="381px"
        android:src="@drawable/p_16_dd_parts_key_delete"/>
    <ImageView
        android:id="@+id/mst2"
        android:background="@drawable/p_16_dd_parts_tm_testshot_delete_key"
        android:layout_width="96px"
        android:layout_height="48px"
        android:layout_marginLeft="439px"
        android:layout_marginTop="381px"/>
    <com.sony.imaging.app.util.RelativeLayoutGroup
        android:id="@+id/battery_icon_on"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        base:group="BatteryIcon">
        <LinearLayout
            android:gravity="right"
            android:layout_width="105px"
            android:layout_height="wrap_content"
            android:layout_marginLeft="535px"
            android:layout_marginTop="0px">
            <com.sony.imaging.app.base.common.widget.BatteryIcon
                android:id="@+id/i10_2"
                android:layout_width="49px"
                android:layout_height="32px"
                android:layout_marginLeft="0px"
                android:layout_marginTop="2px"
                android:src="@drawable/icon_battery"/>
            <com.sony.imaging.app.base.common.widget.BatteryLevelText
                android:typeface="4"
                android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
                android:gravity="left"
                android:id="@+id/i1_1"
                android:layout_width="58px"
                android:layout_height="36px"
                android:layout_marginLeft="-2px"
                android:layout_marginTop="0px"
                style="@style/RESID_FONTSIZE_SP_REC_BASE_INFO"/>
        </LinearLayout>
    </com.sony.imaging.app.util.RelativeLayoutGroup>
    <com.sony.imaging.app.util.RelativeLayoutGroup
        android:id="@+id/battery_icon_only_preend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        base:group="BatteryIcon">
        <com.sony.imaging.app.base.common.widget.BatteryIcon
            android:id="@+id/i10_2"
            android:layout_width="49px"
            android:layout_height="32px"
            android:layout_marginLeft="535px"
            android:layout_marginTop="2px"
            android:src="@drawable/icon_preend_battery"/>
    </com.sony.imaging.app.util.RelativeLayoutGroup>
    <com.sony.imaging.app.base.shooting.widget.FocusMagnificationGuide
        android:id="@+id/magnification_position_view"
        android:layout_width="96px"
        android:layout_height="98px"
        android:layout_marginLeft="40px"
        android:layout_marginTop="314px"/>
    <com.sony.imaging.app.base.shooting.widget.FocusModeIcon
        android:id="@+id/magnification_focus_mode_icon"
        android:layout_width="70px"
        android:layout_height="60px"
        android:layout_marginLeft="570px"
        android:layout_marginTop="368px"
        base:af_a="0x1081369"
        base:af_s="0x1081345"
        base:af_c="0x108138c"
        base:mf="@android:drawable/text_select_handle_middle_material"
        base:dmf="@android:drawable/text_select_handle_right_material"/>
    <com.sony.imaging.app.base.common.widget.SteadyShotErrorIcon
        android:id="@+id/camera_shake_error"
        android:layout_width="76px"
        android:layout_height="36px"
        android:layout_marginLeft="340px"
        android:layout_marginTop="79px"/>
    <com.sony.imaging.app.base.shooting.widget.TouchOffIcon
        android:id="@+id/i1_10"
        android:layout_width="96px"
        android:layout_height="48px"
        android:layout_marginLeft="540px"
        android:layout_marginTop="40px"
        android:src="0x1080f05"/>
    <com.sony.imaging.app.base.common.widget.AbnormalTemperatureIcon
        android:id="@+id/abnormal_icon"
        android:layout_width="34px"
        android:layout_height="36px"
        android:layout_marginLeft="304px"
        android:layout_marginTop="79px"
        android:scaleType="center"
        base:heat="0x1080d13"/>
    <com.sony.imaging.app.base.common.widget.DatabaseIcon
        android:id="@+id/DatabaseIcon"
        android:layout_width="60px"
        android:layout_height="36px"
        android:layout_marginLeft="242px"
        android:layout_marginTop="79px"
        android:scaleType="center"
        base:database_error="@android:drawable/sym_keyboard_shift"
        base:database_full="0x10809fa"/>
    <com.sony.imaging.app.base.common.widget.FinderErrorIcon
        android:id="@+id/FinderErrorIcon"
        android:layout_width="52px"
        android:layout_height="36px"
        android:layout_marginLeft="188px"
        android:layout_marginTop="79px"
        android:scaleType="center"
        base:finder_error="@android:drawable/jog_tab_bar_left_generic"/>
    <include
        android:id="@+id/shooting_parts_sid_footer"
        layout="@layout/shooting_parts_sid_footer_panel"/>
</RelativeLayout>
