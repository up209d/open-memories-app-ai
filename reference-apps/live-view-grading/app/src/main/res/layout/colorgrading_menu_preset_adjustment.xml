<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/colorgrading_menu_sub"
        layout="@layout/colorgrading_adjustment_menu_special"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/TextView"
        android:layout_width="604px"
        android:layout_height="46px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="6px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="right"
        android:id="@+id/vertical_sb_progresstext"
        android:layout_width="69px"
        android:layout_height="46px"
        android:layout_marginLeft="511px"
        android:layout_marginTop="178px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <ImageView
        android:id="@+id/vsb_src"
        android:background="@drawable/p_16_dd_parts_oc_adjust_common_gauge_background"
        android:layout_width="72px"
        android:layout_height="226px"
        android:layout_marginLeft="568px"
        android:layout_marginTop="88px"
        android:src="@drawable/p_16_dd_parts_oc_adjust_common_gauge_scale"/>
    <com.sony.imaging.app.liveviewgrading.menu.widget.VerticalSeekBar
        android:id="@+id/vertical_Seekbar"
        android:layout_width="72px"
        android:layout_height="226px"
        android:layout_marginLeft="588px"
        android:layout_marginTop="88px"
        android:progressDrawable="@null"
        android:thumb="@drawable/p_16_dd_parts_common_gauge_scale_circle"
        android:thumbOffset="0px"/>
    <ImageView
        android:id="@+id/gauge_low"
        android:layout_width="32px"
        android:layout_height="32px"
        android:layout_marginLeft="588px"
        android:layout_marginTop="312px"
        android:src="@drawable/p_16_dd_parts_lvg_param_gauge_minus"/>
    <ImageView
        android:id="@+id/gauge_high"
        android:layout_width="32px"
        android:layout_height="32px"
        android:layout_marginLeft="588px"
        android:layout_marginTop="58px"
        android:src="@drawable/p_16_dd_parts_lvg_param_gauge_plus"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="right"
        android:id="@+id/gauge_text"
        android:layout_width="69px"
        android:layout_height="46px"
        android:layout_marginLeft="511px"
        android:layout_marginTop="178px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <include
        android:id="@+id/group_1"
        layout="@layout/param_group_1"/>
    <include
        android:id="@+id/group_2"
        layout="@layout/param_group_2"/>
    <include
        android:id="@+id/group_3"
        layout="@layout/param_group_3"/>
</RelativeLayout>
