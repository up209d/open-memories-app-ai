<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/group1_bg"
        android:background="@drawable/p_16_dd_parts_common_button_background"
        android:visibility="invisible"
        android:layout_width="360px"
        android:layout_height="60px"
        android:layout_marginLeft="140px"
        android:layout_marginTop="360px">
        <ImageView
            android:background="@drawable/p_16_dd_parts_pe_parameter_separater"
            android:layout_width="2px"
            android:layout_height="60px"
            android:layout_marginLeft="118px"/>
