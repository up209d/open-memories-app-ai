<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/theme_guide_background"
        android:background="@drawable/p_16_dd_parts_mle_guide_base"
        android:layout_width="600px"
        android:layout_height="416px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="4px"
        android:scaleType="fitXY"/>
    <com.sony.imaging.app.doubleexposure.shooting.wigdet.ThemeGuideFirstImageIcon
        android:id="@+id/theme_guide_first_image"
        android:layout_width="150px"
        android:layout_height="150px"
        android:layout_marginLeft="135px"
        android:layout_marginTop="53px"/>
    <ImageView
        android:id="@+id/theme_guide_arrow"
        android:background="@drawable/p_16_dd_parts_mle_right_arrow_img"
        android:layout_width="70px"
        android:layout_height="60px"
        android:layout_marginLeft="285px"
        android:layout_marginTop="98px"/>
    <com.sony.imaging.app.doubleexposure.shooting.wigdet.ThemeGuideSecondImageIcon
        android:id="@+id/theme_guide_second_image"
        android:layout_width="150px"
        android:layout_height="150px"
        android:layout_marginLeft="355px"
        android:layout_marginTop="53px"/>
    <com.sony.imaging.app.doubleexposure.shooting.wigdet.ThemeGuideText
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/theme_guide_text"
        android:layout_width="484px"
        android:layout_height="112px"
        android:layout_marginLeft="78px"
        android:layout_marginTop="229px"
        style="@style/RESID_FONTSIZE_STD_L_EDGE_OFF"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:layout_width="564px"
        android:layout_height="40px"
        android:layout_marginLeft="38px"
        android:layout_marginTop="363px"
        base:guide_text_style="@attr/footer_guide"
        base:guide_text_marginLeft="5px"
        base:guide_text_marginTop="0px"
        base:guide_text_width="564px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/years"
        base:guide_text_emt="@android:string/years"/>
</RelativeLayout>
