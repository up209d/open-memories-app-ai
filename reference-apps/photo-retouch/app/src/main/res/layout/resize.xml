<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/resize_background"
        android:background="#000000"
        android:layout_width="640px"
        android:layout_height="480px"
        android:layout_marginLeft="0px"/>
    <RelativeLayout
        android:id="@+id/CanResize"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px">
        <TextView
            android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
            android:gravity="center"
            android:id="@+id/ResizeMessage"
            android:layout_width="580px"
            android:layout_height="88px"
            android:layout_marginLeft="30px"
            android:layout_marginTop="249px"
            style="@style/RESID_FONTSIZE_L"/>
        <ImageView
            android:id="@+id/CurrentSize"
            android:layout_width="80px"
            android:layout_height="80px"
            android:layout_marginLeft="140px"
            android:layout_marginTop="120px"/>
        <ImageView
            android:background="@drawable/p_16_dd_parts_pr_resize_to"
            android:layout_width="80px"
            android:layout_height="80px"
            android:layout_marginLeft="240px"
            android:layout_marginTop="120px"/>
        <com.sony.imaging.app.photoretouch.common.widget.EachButton
            android:id="@+id/BtnResizeToM"
            android:layout_width="80px"
            android:layout_height="80px"
            android:layout_marginLeft="340px"
            android:layout_marginTop="120px"
            android:src="@drawable/btnimage_focused"/>
        <com.sony.imaging.app.photoretouch.common.widget.EachButton
            android:id="@+id/BtnResizeToS"
            android:layout_width="80px"
            android:layout_height="80px"
            android:layout_marginLeft="440px"
            android:layout_marginTop="120px"
            android:src="@drawable/btnimage_focused"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/NoResize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px">
        <ImageView
            android:id="@+id/NoResizeIcon"
            android:background="@drawable/p_16_dd_parts_pr_resizes_normal"
            android:layout_width="80px"
            android:layout_height="80px"
            android:layout_marginLeft="280px"
            android:layout_marginTop="120px"/>
        <TextView
            android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
            android:gravity="center"
            android:id="@+id/NoResizeDesc"
            android:layout_width="580px"
            android:layout_height="88px"
            android:layout_marginLeft="30px"
            android:layout_marginTop="249px"
            style="@style/RESID_FONTSIZE_L"/>
    </RelativeLayout>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/date_picker_decrement_day_button"
        base:guide_text_emt="@android:string/hardware"/>
</RelativeLayout>
