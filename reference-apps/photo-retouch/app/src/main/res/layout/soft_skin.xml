<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:id="@+id/parent_layout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/softskin_background"
        android:background="#000000"
        android:layout_width="640px"
        android:layout_height="480px"
        android:layout_marginLeft="0px"/>
    <com.sony.scalar.widget.OptimizedImageView
        android:id="@+id/onePhoto"
        android:layout_width="324px"
        android:layout_height="288px"
        android:layout_marginLeft="106px"
        android:layout_marginTop="54px"/>
    <FrameLayout
        android:id="@+id/frameLayout"
        android:background="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <com.sony.imaging.app.photoretouch.common.widget.EachButton
        android:id="@+id/beauty_skin_0"
        android:layout_width="96px"
        android:layout_height="66px"
        android:layout_marginLeft="128px"
        android:layout_marginTop="344px"
        android:src="@drawable/btnimage_focused"/>
    <com.sony.imaging.app.photoretouch.common.widget.EachButton
        android:id="@+id/beauty_skin_1"
        android:layout_width="96px"
        android:layout_height="66px"
        android:layout_marginLeft="224px"
        android:layout_marginTop="344px"
        android:src="@drawable/btnimage_focused"/>
    <com.sony.imaging.app.photoretouch.common.widget.EachButton
        android:id="@+id/beauty_skin_2"
        android:layout_width="96px"
        android:layout_height="66px"
        android:layout_marginLeft="320px"
        android:layout_marginTop="344px"
        android:src="@drawable/btnimage_focused"/>
    <com.sony.imaging.app.photoretouch.common.widget.EachButton
        android:id="@+id/beauty_skin_3"
        android:layout_width="96px"
        android:layout_height="66px"
        android:layout_marginLeft="416px"
        android:layout_marginTop="344px"
        android:src="@drawable/btnimage_focused"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/date_picker_decrement_day_button"
        base:guide_text_emt="@android:string/hardware"/>
</RelativeLayout>
