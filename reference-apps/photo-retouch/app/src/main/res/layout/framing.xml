<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/framing_background"
        android:background="#000000"
        android:layout_width="640px"
        android:layout_height="480px"
        android:layout_marginLeft="0px"/>
    <com.sony.imaging.app.photoretouch.common.CustomGallery
        android:id="@+id/gallery"
        android:layout_width="540px"
        android:layout_height="360px"
        android:layout_marginLeft="50px"
        android:layout_marginTop="0px"/>
    <ImageButton
        android:id="@+id/Btn_face1"
        android:visibility="invisible"
        android:layout_width="80px"
        android:layout_height="80px"
        android:layout_marginLeft="94px"
        android:layout_marginTop="387px"
        android:scaleType="fitXY"/>
    <ImageButton
        android:id="@+id/Btn_face2"
        android:visibility="invisible"
        android:layout_width="80px"
        android:layout_height="80px"
        android:layout_marginLeft="94px"
        android:layout_marginTop="387px"
        android:scaleType="fitXY"/>
    <ImageButton
        android:id="@+id/Btn_face3"
        android:visibility="invisible"
        android:layout_width="80px"
        android:layout_height="80px"
        android:layout_marginLeft="94px"
        android:layout_marginTop="387px"
        android:scaleType="fitXY"/>
    <ImageButton
        android:id="@+id/Btn_face4"
        android:visibility="invisible"
        android:layout_width="80px"
        android:layout_height="80px"
        android:layout_marginLeft="94px"
        android:layout_marginTop="387px"
        android:scaleType="fitXY"/>
    <ImageButton
        android:id="@+id/Btn_face5"
        android:visibility="invisible"
        android:layout_width="80px"
        android:layout_height="80px"
        android:layout_marginLeft="94px"
        android:layout_marginTop="387px"
        android:scaleType="fitXY"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@string/STRID_FOOTERGUIDE_MANUAL_CANCEL_BY_MENU"
        base:guide_text_emt="@string/STRID_FOOTERGUIDE_MANUAL_CANCEL_FOR_SK"/>
</RelativeLayout>
