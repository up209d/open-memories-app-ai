<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"
        android:src="@android:drawable/list_longpressed_holo_dark"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/menu_screen_title"
        android:layout_width="604px"
        android:layout_height="46px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="6px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <ImageView
        android:layout_width="72px"
        android:layout_height="68px"
        android:layout_marginLeft="209px"
        android:layout_marginTop="119px"
        android:src="0x10809c4"/>
    <ImageView
        android:id="@+id/left_arrow"
        android:layout_width="21px"
        android:layout_height="38px"
        android:layout_marginLeft="291px"
        android:layout_marginTop="134px"
        android:src="0x1081746"/>
    <ImageView
        android:id="@+id/right_arrow"
        android:layout_width="21px"
        android:layout_height="38px"
        android:layout_marginLeft="404px"
        android:layout_marginTop="134px"
        android:src="0x1081378"/>
    <com.sony.imaging.app.base.shooting.widget.CompensationWheelAndInfoView
        android:id="@+id/CompensationWheelAndInfoView"
        android:layout_width="640px"
        android:layout_height="165px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="130px"
        base:compbar5_left_n="0x1080983"
        base:compbar5_left_d="0x108097c"
        base:compbar5_center="0x1080d87"
        base:compbar5_right_n="0x1080edd"
        base:compbar5_right_d="0x1080ed7"
        base:compbar3_left_n="@android:drawable/jog_tab_right_decline"
        base:compbar3_left_d="@android:drawable/jog_tab_bar_right_sound_on"
        base:compbar3_center="0x1080eef"
        base:compbar3_right_n="@android:drawable/popup_center_dark"
        base:compbar3_right_d="@android:drawable/popup_background_mtrl_mult"
        base:compbar2_left_minus="0x10818be"
        base:compbar2_center="0x1080eef"
        base:compbar2_right_plus="0x10818c1"
        base:compind_upper="0x10810ee"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/menu_screen_footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_marginLeft="148px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="484px"
        base:guide_text_height="40px"/>
    <com.sony.imaging.app.base.shooting.widget.MovieRecStateIcon
        android:gravity="right"
        android:layout_width="138px"
        android:layout_height="40px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="432px"
        base:text_rec="@android:string/mmcc_authentication_reject"
        base:text_standby="0x1040bd4"/>
</RelativeLayout>
