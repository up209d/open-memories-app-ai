<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/GuideBaseWindow"
        android:background="@drawable/p_16_dd_parts_pr_basewindow"
        android:layout_width="540px"
        android:layout_height="378px"
        android:layout_marginLeft="100px"
        android:layout_marginTop="51px"/>
    <ImageView
        android:id="@+id/GuideBackground"
        android:layout_width="364px"
        android:layout_height="322px"
        android:layout_marginLeft="255px"
        android:layout_marginTop="79px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/ToolName"
        android:layout_width="484px"
        android:layout_height="40px"
        android:layout_marginLeft="128px"
        android:layout_marginTop="88px"
        style="@style/RESID_FONTSIZE_L"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="top|left"
        android:id="@+id/ToolGuide"
        android:layout_width="484px"
        android:layout_height="168px"
        android:layout_marginLeft="128px"
        android:layout_marginTop="136px"
        style="@style/RESID_FONTSIZE_M"/>
    <Button
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/BtnOK"
        android:background="@drawable/state_single_btn_guide_ok"
        android:paddingTop="10px"
        android:layout_width="264px"
        android:layout_height="82px"
        android:layout_marginLeft="237px"
        android:layout_marginTop="311px"
        style="@style/RESID_FONTSIZE_M"/>
</RelativeLayout>
