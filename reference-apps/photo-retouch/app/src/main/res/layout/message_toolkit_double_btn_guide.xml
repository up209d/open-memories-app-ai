<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/block_touch_below_guide_layout"
        android:background="@drawable/p_16_dd_parts_pr_grayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="100px"/>
    <ImageView
        android:id="@+id/block_touch_on_rotate_btn"
        android:background="@drawable/p_16_dd_parts_pr_grayoutlefttop"
        android:layout_width="100px"
        android:layout_height="96px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="-18px"/>
    <ImageView
        android:id="@+id/block_touch_on_back_btn"
        android:background="@drawable/p_16_dd_parts_pr_grayoutleftbottom"
        android:layout_width="100px"
        android:layout_height="96px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="402px"/>
    <ImageView
        android:id="@+id/GuideBaseWindow"
        android:background="@drawable/p_16_dd_parts_pr_basewindow"
        android:layout_width="540px"
        android:layout_height="420px"
        android:layout_marginLeft="100px"
        android:layout_marginTop="9px"/>
    <ImageView
        android:id="@+id/GuideBackground"
        android:layout_width="364px"
        android:layout_height="364px"
        android:layout_marginLeft="255px"
        android:layout_marginTop="37px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/ToolName"
        android:layout_width="484px"
        android:layout_height="40px"
        android:layout_marginLeft="128px"
        android:layout_marginTop="46px"
        style="@style/RESID_FONTSIZE_L"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="top|left"
        android:id="@+id/ToolGuide"
        android:layout_width="484px"
        android:layout_height="168px"
        android:layout_marginLeft="128px"
        android:layout_marginTop="94px"
        style="@style/RESID_FONTSIZE_M"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/Continue"
        android:layout_width="484px"
        android:layout_height="40px"
        android:layout_marginLeft="128px"
        android:layout_marginTop="270px"
        style="@style/RESID_FONTSIZE_M"/>
    <Button
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/BtnOK"
        android:background="@drawable/state_double_btn_guide_ok_cancel"
        android:paddingTop="10px"
        android:layout_width="240px"
        android:layout_height="82px"
        android:layout_marginLeft="128px"
        android:layout_marginTop="311px"
        style="@style/RESID_FONTSIZE_M"/>
    <Button
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/BtnCancel"
        android:background="@drawable/state_double_btn_guide_ok_cancel"
        android:paddingTop="10px"
        android:layout_width="240px"
        android:layout_height="82px"
        android:layout_marginLeft="372px"
        android:layout_marginTop="311px"
        style="@style/RESID_FONTSIZE_M"/>
</RelativeLayout>
