<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/block_touch_below_guide_layout"
        android:background="@drawable/p_16_dd_parts_pr_grayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <ImageView
        android:background="@drawable/p_16_dd_parts_pr_basewindow"
        android:layout_width="520px"
        android:layout_height="124px"
        android:layout_marginLeft="60px"
        android:layout_marginTop="178px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/msg_alert"
        android:layout_width="500px"
        android:layout_height="88px"
        android:layout_marginLeft="70px"
        android:layout_marginTop="219px"
        android:layout_centerInParent="true"
        style="@style/RESID_FONTSIZE_M"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/zen_mode_alarm"
        base:guide_text_emt="@android:string/zen_mode_alarm"/>
</RelativeLayout>
