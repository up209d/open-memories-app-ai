<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/horizontal_background"
        android:background="#000000"
        android:layout_width="640px"
        android:layout_height="480px"
        android:layout_marginLeft="0px"/>
    <com.sony.scalar.widget.OptimizedImageView
        android:id="@+id/optimized_image"
        android:layout_width="324px"
        android:layout_height="288px"
        android:layout_marginLeft="106px"
        android:layout_marginTop="54px"/>
    <RelativeLayout
        android:background="@drawable/p_16_dd_parts_pr_degreeindicator"
        android:layout_width="480px"
        android:layout_height="64px"
        android:layout_marginLeft="80px"
        android:layout_marginTop="356px"/>
    <SeekBar
        android:id="@+id/slider"
        android:paddingLeft="21px"
        android:paddingRight="21px"
        android:layout_width="500px"
        android:layout_height="64px"
        android:layout_marginLeft="70px"
        android:layout_marginTop="336px"
        android:max="140"
        android:progress="70"
        android:progressDrawable="@android:color/transparent"
        android:minWidth="60px"
        android:minHeight="80px"
        android:thumb="@drawable/p_16_dd_parts_pr_horizontaladjuctment_marker"/>
    <ImageView
        android:id="@+id/HGridLineArea"
        android:layout_width="48px"
        android:layout_height="440px"
        android:layout_marginTop="0px"/>
    <ImageView
        android:id="@+id/VGridLineArea"
        android:layout_width="525px"
        android:layout_height="64px"
        android:layout_marginTop="0px"/>
    <RelativeLayout
        android:id="@+id/GridLineContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="0px">
        <ImageView
            android:id="@+id/gridline_horizontal"
            android:background="@drawable/p_16_dd_parts_pr_hgridline"
            android:layout_width="529px"
            android:layout_height="64px"
            android:layout_marginLeft="42px"
            android:layout_marginTop="148px"/>
        <ImageView
            android:id="@+id/gridline_vertical"
            android:background="@drawable/p_16_dd_parts_pr_vgridline"
            android:layout_width="64px"
            android:layout_height="333px"
            android:layout_marginLeft="288px"
            android:layout_marginTop="0px"/>
    </RelativeLayout>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@string/STRID_FOOTERGUIDE_GRID_CANCEL_BY_MENU"
        base:guide_text_emt="@string/STRID_FOOTERGUIDE_GRID_CANCEL_FOR_SK"/>
</RelativeLayout>
