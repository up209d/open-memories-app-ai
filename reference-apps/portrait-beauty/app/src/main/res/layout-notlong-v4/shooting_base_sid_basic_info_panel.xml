            android:focusable="false"
            android:focusableInTouchMode="false"
            android:layout_width="96px"
            android:layout_height="48px"
            android:layout_marginLeft="429px"
            android:layout_marginTop="381px"
            android:scaleType="fitXY"/>
        <ImageView
            android:id="@+id/menu_guide_live_view_eycs"
            android:background="@drawable/p_16_dd_parts_iconguide_setting"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:layout_width="96px"
            android:layout_height="48px"
            android:layout_marginLeft="449px"
            android:layout_marginTop="383px"
            android:scaleType="fitXY"/>
        <ImageView
            android:id="@+id/parts_sk1_live_view_eycs"
            android:background="@drawable/p_16_dd_parts_key_sk1"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:layout_width="96px"
            android:layout_height="48px"
            android:layout_marginLeft="429px"
            android:layout_marginTop="329px"
            android:scaleType="fitXY"/>
        <ImageView
            android:id="@+id/icon_guide_live_view_eycs"
            android:background="@drawable/p_16_dd_parts_guide_menu"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:layout_width="96px"
            android:layout_height="48px"
            android:layout_marginLeft="449px"
            android:layout_marginTop="329px"
            android:scaleType="fitXY"/>
