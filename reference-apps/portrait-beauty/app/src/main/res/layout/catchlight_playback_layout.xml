<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/common_optimized_image_view"
        layout="@layout/common_optimized_image_view"/>
    <com.sony.imaging.app.portraitbeauty.shooting.widget.EachButton
        android:id="@+id/btn_left_eye"
        android:background="@drawable/btn_transparent_border"
        android:layout_width="240px"
        android:layout_height="160px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="210px"
        android:scaleType="matrix"/>
    <com.sony.imaging.app.portraitbeauty.shooting.widget.EachButton
        android:id="@+id/btn_right_eye"
        android:background="@drawable/btn_transparent_border"
        android:layout_width="240px"
        android:layout_height="160px"
        android:layout_marginLeft="300px"
        android:layout_marginTop="210px"
        android:scaleType="matrix"/>
    <FrameLayout
        android:id="@+id/frameLayout"
        android:background="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:id="@+id/frameLayoutEye"
        android:background="@android:color/transparent"
        android:layout_width="540px"
        android:layout_height="480px"/>
    <ImageView
        android:id="@+id/catchlight_focus_arrows"
        android:layout_width="232px"
        android:layout_height="122px"
        android:layout_marginLeft="314px"
        android:layout_marginTop="234px"
        android:src="@drawable/p_16_dd_parts_portraitbeauty_catchlight_arrow"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@string/STRID_FUNC_SELFIE_CL_ADJUST_FGUIDE_EYCS"
        base:guide_text_emt="@string/STRID_FUNC_SELFIE_CL_ADJUST_FGUIDE_PJONE"/>
</RelativeLayout>
