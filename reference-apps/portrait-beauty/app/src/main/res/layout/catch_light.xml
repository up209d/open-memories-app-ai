<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parent_layout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/catchlight_background"
        android:layout_width="640px"
        android:layout_height="480px"
        android:layout_marginLeft="0px"
        android:src="@drawable/p_16_dd_parts_mle_guide_base"/>
    <com.sony.imaging.app.base.common.widget.SoftKeyArea
        android:id="@+id/softkeyarea"
        android:layout_width="120px"
        android:layout_height="516px"
        android:layout_marginLeft="520px"
        android:layout_marginTop="-18px"
        android:layout_marginBottom="-18px"/>
    <com.sony.scalar.widget.OptimizedImageView
        android:id="@+id/onePhoto"
        android:layout_width="324px"
        android:layout_height="288px"
        android:layout_marginLeft="106px"
        android:layout_marginTop="54px"/>
    <FrameLayout
        android:id="@+id/frameLayout"
        android:background="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <FrameLayout
        android:id="@+id/frameLayoutEye"
        android:background="@android:color/transparent"
        android:layout_width="540px"
        android:layout_height="480px"/>
    <com.sony.imaging.app.portraitbeauty.common.widget.EachButton xmlns:base="http://schemas.android.com/apk/res/auto"
        android:id="@+id/btn_left_eye"
        android:background="@drawable/btn_transparent_border"
        android:layout_width="240px"
        android:layout_height="160px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="310px"
        android:scaleType="matrix"/>
    <com.sony.imaging.app.portraitbeauty.common.widget.EachButton
        android:id="@+id/btn_right_eye"
        android:background="@drawable/btn_transparent_border"
        android:layout_width="240px"
        android:layout_height="160px"
        android:layout_marginLeft="300px"
        android:layout_marginTop="310px"
        android:scaleType="matrix"/>
    <ImageView
        android:id="@+id/catchlight_focus_arrows"
        android:layout_width="232px"
        android:layout_height="122px"
        android:layout_marginLeft="314px"
        android:layout_marginTop="234px"
        android:src="@drawable/p_16_dd_parts_portraitbeauty_catchlight_arrow"/>
</RelativeLayout>
