<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.sony.imaging.app.base.playback.widget.ShutterSpeed
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/shutterspeed"
        android:layout_width="88px"
        android:layout_height="36px"
        android:layout_marginLeft="276px"
        android:layout_marginTop="401px"
        style="@style/RESID_FONTSIZE_SP_PLAY_INFO"/>
    <com.sony.imaging.app.base.playback.widget.PictureEffect
        android:id="@+id/pictureeffect"
        android:layout_width="90px"
        android:layout_height="46px"
        android:layout_marginLeft="445px"
        android:layout_marginTop="352px"
        base:pic_effect_only_err_display="true"
        base:pe_err_hdr_l="@android:drawable/quickactions_arrowdown_right_holo_dark"
        base:pe_err_hdr_m="@android:drawable/spinner_dropdown_background_down"
        base:pe_err_hdr_h="@android:drawable/search_dropdown_background"
        base:pe_err_rich_mono="0x1080981"/>
    <com.sony.imaging.app.base.playback.widget.DROAutoHDR
        android:id="@+id/droautohdr"
        android:layout_width="77px"
        android:layout_height="48px"
        android:layout_marginLeft="559px"
        android:layout_marginTop="351px"
        base:dro_hdr_icon_width="77px"
        base:dro_hdr_icon_height="48px"
        base:dro_hdr_icon_marginLeft="0px"
        base:dro_hdr_icon_marginTop="0px"
        base:dro_hdr_only_err_display="true"
        base:dro_hdr_hdr_err="0x108126d"/>
    <com.sony.imaging.app.base.playback.widget.Aperture
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/aperture"
        android:layout_width="60px"
        android:layout_height="36px"
        android:layout_marginLeft="412px"
        android:layout_marginTop="401px"
        style="@style/RESID_FONTSIZE_SP_PLAY_INFO"/>
    <com.sony.imaging.app.base.playback.widget.ISO
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/iso"
        android:layout_width="126px"
        android:layout_height="36px"
        android:layout_marginLeft="510px"
        android:layout_marginTop="401px"
        base:iso_text_width="74px"
        base:iso_text_height="36px"
        base:iso_text_marginLeft="52px"
        base:iso_text_marginTop="0px"
        base:iso_icon_width="48px"
        base:iso_icon_height="34px"
        base:iso_icon_marginLeft="0px"
        base:iso_icon_marginTop="1px"
        style="@style/RESID_FONTSIZE_SP_PLAY_INFO"/>
</RelativeLayout>
