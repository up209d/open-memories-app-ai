        android:id="@+id/NDFilterFeedbackIcon"
        android:layout_width="34px"
        android:layout_height="24px"
        android:layout_marginLeft="596px"
        android:layout_marginTop="455px"
        base:ndfilter_feedback="0x10818d9"/>
