        android:id="@+id/iso_sensitivity_view"
        android:background="@android:color/transparent"
        android:layout_width="96px"
        android:layout_height="26px"
        android:layout_marginLeft="466px"
        android:layout_marginTop="454px"
        android:src="0x10810ec"
        base:iso_icon_vertical_top_offset="1px"
        base:iso_icon_width="32px"
        base:iso_icon_height="22px"
        base:upper_line_x_offset="32px"
        base:upper_line_y_offset="2px"
        base:lower_line_x_offset="32px"
        base:lower_line_y_offset="23px"
