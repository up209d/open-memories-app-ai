<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:id="@+id/caution_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.sony.imaging.app.base.common.widget.SubLcdIconView
        android:id="@+id/icon_wifi"
        android:layout_width="87px"
        android:layout_height="52px"
        android:layout_marginLeft="216px"
        android:layout_marginTop="63px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        base:sublcd_lid="LID_SUBLCD_WIFI_STATE"
        base:sublcd_pattern="PTN_OFF"
        base:sublcd_lkid="LKID_SUBLCD_WIFI_STATE"/>
    <com.sony.imaging.app.base.common.widget.SubLcdIconView
        android:id="@+id/icon_airplane"
        android:layout_width="66px"
        android:layout_height="52px"
        android:layout_marginLeft="412px"
        android:layout_marginTop="63px"
        base:sublcd_lid="LID_SUBLCD_AIRPLANE"
        base:sublcd_pattern="PTN_ON"
        base:sublcd_lkid="LKID_SUBLCD_AIRPLANE"/>
    <com.sony.imaging.app.base.common.widget.SubLcdIconView
        android:id="@+id/icon_media"
        android:layout_width="55px"
        android:layout_height="52px"
        android:layout_marginLeft="444px"
        android:layout_marginTop="141px"
        base:sublcd_lid="LID_SUBLCD_MDEIA_ERR_STATE"
        base:sublcd_pattern="PTN_ON"
        base:sublcd_lkid="LKID_SUBLCD_MDEIA_ERR_STATE"/>
    <com.sony.imaging.app.base.common.widget.BatteryIcon
        android:id="@+id/icon_battery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="499px"
        android:layout_marginTop="63px"
        android:src="@drawable/icon_battery"/>
    <com.sony.imaging.app.base.common.widget.SubLcdIconView
        android:id="@+id/icon_steady_shot"
        android:layout_width="83px"
        android:layout_height="52px"
        android:layout_marginLeft="507px"
        android:layout_marginTop="131px"
        base:sublcd_lid="LID_SUBLCD_STEADY_SHOT"
        base:sublcd_pattern="PTN_ON"
        base:sublcd_lkid="LKID_SUBLCD_STEADY_SHOT"/>
    <com.sony.imaging.app.base.common.widget.SubLcdIconView
        android:id="@+id/icon_xavcs"
        android:layout_width="83px"
        android:layout_height="52px"
        android:layout_marginLeft="507px"
        android:layout_marginTop="131px"
        base:sublcd_lid="LID_SUBLCD_XAVCS"
        base:sublcd_pattern="PTN_ON"
        base:sublcd_lkid="LKID_SUBLCD_XAVCS"/>
    <com.sony.imaging.app.base.common.widget.SubLcdIconView
        android:id="@+id/icon_audio_off"
        android:layout_width="83px"
        android:layout_height="52px"
        android:layout_marginLeft="507px"
        android:layout_marginTop="131px"
        base:sublcd_lid="LID_SUBLCD_MIC_OFF"
        base:sublcd_pattern="PTN_ON"
        base:sublcd_lkid="LKID_SUBLCD_MIC_OFF"/>
    <com.sony.imaging.app.base.common.widget.SubLcdTextView
        android:id="@+id/caution_text"
        android:layout_width="360px"
        android:layout_height="82px"
        android:layout_marginLeft="216px"
        android:layout_marginTop="263px"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        base:sublcd_lid="LID_SUBLCD_INFOMATION"
        base:sublcd_pattern="PTN_ON"/>
    <com.sony.imaging.app.base.common.widget.SubLcdTextView
        android:id="@+id/caution_resolution"
        android:layout_width="112px"
        android:layout_height="62px"
        android:layout_marginLeft="158px"
        android:layout_marginTop="190px"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        base:sublcd_lid="LID_SUBLCD_RESOLUTION_7SEG"
        base:sublcd_pattern="PTN_ON"/>
    <com.sony.imaging.app.base.common.widget.SubLcdTextView
        android:id="@+id/caution_rate"
        android:layout_width="112px"
        android:layout_height="62px"
        android:layout_marginLeft="391px"
        android:layout_marginTop="190px"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        base:sublcd_lid="LID_SUBLCD_FRAME_RATE_7SEG"
        base:sublcd_pattern="PTN_ON"/>
</RelativeLayout>
