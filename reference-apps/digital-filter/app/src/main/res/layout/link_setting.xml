<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="100px"
    android:layout_height="225px">
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/item_name"
        android:layout_width="86px"
        android:layout_height="38px"
        android:layout_marginLeft="5px"
        android:layout_marginTop="2px"
        android:text="@null"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <ImageView
        android:gravity="center"
        android:id="@+id/item_icon"
        android:layout_width="36px"
        android:layout_height="34px"
        android:layout_marginLeft="30px"
        android:layout_marginTop="6px"
        android:src="@null"/>
    <ImageView
        android:id="@+id/parent0"
        android:layout_width="24px"
        android:layout_height="24px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="45px"
        android:src="@drawable/p_16_dd_parts_skyhdr_link_set_parent"/>
    <ImageView
        android:id="@+id/parent1"
        android:layout_width="24px"
        android:layout_height="24px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="90px"
        android:src="@drawable/p_16_dd_parts_skyhdr_link_set_parent"/>
    <ImageView
        android:id="@+id/parent2"
        android:layout_width="24px"
        android:layout_height="24px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="135px"
        android:src="@drawable/p_16_dd_parts_skyhdr_link_set_parent"/>
    <TextView
        android:id="@+id/focus0"
        android:background="@drawable/bt_x_18"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="40px"
        android:layout_height="40px"
        android:layout_marginLeft="28px"
        android:layout_marginTop="45px"/>
    <TextView
        android:id="@+id/focus1"
        android:background="@drawable/bt_x_18"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="40px"
        android:layout_height="40px"
        android:layout_marginLeft="28px"
        android:layout_marginTop="90px"/>
    <TextView
        android:id="@+id/focus2"
        android:background="@drawable/bt_x_18"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="40px"
        android:layout_height="40px"
        android:layout_marginLeft="28px"
        android:layout_marginTop="135px"/>
    <ImageView
        android:id="@+id/check_box0"
        android:background="0x10814a2"
        android:layout_width="32px"
        android:layout_height="32px"
        android:layout_marginLeft="32px"
        android:layout_marginTop="49px"/>
    <ImageView
        android:id="@+id/check_box1"
        android:background="0x10814a2"
        android:layout_width="32px"
        android:layout_height="32px"
        android:layout_marginLeft="32px"
        android:layout_marginTop="94px"/>
    <ImageView
        android:id="@+id/check_box2"
        android:background="0x10814a2"
        android:layout_width="32px"
        android:layout_height="32px"
        android:layout_marginLeft="32px"
        android:layout_marginTop="139px"/>
    <TextView
        android:id="@+id/toggle_all"
        android:background="@drawable/bt_x_18"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="82px"
        android:layout_height="46px"
        android:layout_marginLeft="7px"
        android:layout_marginTop="183px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:layout_width="82px"
        android:layout_height="46px"
        android:layout_marginLeft="7px"
        android:layout_marginTop="183px"
        android:text="ALL"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_OFF"/>
</RelativeLayout>
