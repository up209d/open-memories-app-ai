<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/common_parts_sublcd_header"
        layout="@layout/common_parts_sublcd_header"/>
    <com.sony.imaging.app.base.common.widget.SubLcdTextView
        android:id="@+id/text_info"
        android:layout_width="360px"
        android:layout_height="82px"
        android:layout_marginLeft="216px"
        android:layout_marginTop="263px"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        base:sublcd_lid="LID_SUBLCD_INFOMATION"
        base:sublcd_pattern="PTN_ON"/>
    <com.sony.imaging.app.base.shooting.widget.SubLcdMode
        android:id="@+id/current_mode"
        android:layout_width="10px"
        android:layout_height="10px"/>
</RelativeLayout>
