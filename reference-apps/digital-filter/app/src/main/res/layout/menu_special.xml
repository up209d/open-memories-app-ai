<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.sony.imaging.app.digitalfilter.shooting.widget.BorderView
        android:id="@+id/border_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        base:border_mode="normal"/>
    <ImageView
        android:background="@drawable/p_16_dd_parts_skyhdr_header"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/menu_screen_title"
        android:layout_width="604px"
        android:layout_height="48px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="4px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_FOCUSED"
        android:gravity="center"
        android:id="@+id/menu_item_name"
        android:layout_width="484px"
        android:layout_height="48px"
        android:layout_marginLeft="139px"
        android:layout_marginTop="69px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <com.sony.imaging.app.digitalfilter.shooting.widget.GFGraphView
        android:id="@+id/filter_histgram"
        android:background="0x10810bf"
        android:visibility="gone"
        android:layout_width="132px"
        android:layout_height="36px"
        android:layout_marginLeft="500px"
        android:layout_marginTop="348px"
        base:color="#ffff8800"
        base:hist_mode="filter"/>
    <com.sony.imaging.app.digitalfilter.shooting.widget.GFGraphView
        android:id="@+id/base_histgram"
        android:background="0x10810bf"
        android:visibility="gone"
        android:layout_width="132px"
        android:layout_height="36px"
        android:layout_marginLeft="500px"
        android:layout_marginTop="384px"
        base:color="#ffffffff"
        base:hist_mode="base"/>
    <com.sony.imaging.app.digitalfilter.shooting.widget.GFGraphView
        android:id="@+id/earth_histgram"
        android:background="0x10810bf"
        android:visibility="gone"
        android:layout_width="132px"
        android:layout_height="36px"
        android:layout_marginLeft="500px"
        android:layout_marginTop="384px"
        base:color="#ffffffff"
        base:hist_mode="base"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/autofill_phone_suffix_separator_re"
        base:guide_text_emt="@android:string/httpErrorAuth"/>
    <com.sony.imaging.app.base.shooting.widget.MovieRecStateIcon
        android:gravity="right"
        android:layout_width="138px"
        android:layout_height="40px"
        android:layout_marginLeft="8px"
        android:layout_marginTop="432px"
        base:text_rec="@android:string/mmcc_authentication_reject"
        base:text_standby="0x1040bd4"/>
    <ImageView
        android:background="@drawable/p_16_dd_parts_skyhdr_left_base"
        android:layout_width="112px"
        android:layout_height="366px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="60px"/>
    <com.sony.imaging.app.base.menu.layout.SpecialScreenView
        android:id="@+id/listview"
        android:scrollbars="none"
        android:fadingEdge="none"
        android:layout_width="122px"
        android:layout_height="330px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="75px"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="0px"
        android:smoothScrollbar="true"/>
    <com.sony.imaging.app.base.menu.layout.SpecialScreenArea
        android:id="@+id/listviewarea"
        android:layout_width="640px"
        android:layout_height="480px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"/>
</RelativeLayout>
