<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:background="#ff000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/hedder"
        android:background="0x10811c9"
        android:layout_width="640px"
        android:layout_height="66px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/menu_screen_title"
        android:layout_width="604px"
        android:layout_height="46px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="6px"
        android:text="@string/STRID_FUNC_SKYND_IMPORT"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center_horizontal"
        android:id="@+id/import_msg"
        android:layout_width="544px"
        android:layout_height="210px"
        android:layout_marginLeft="38px"
        android:layout_marginTop="110px"
        android:text="@string/STRID_FUNC_DF_COPY_MSG"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_OFF"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:background="@drawable/p_16_dd_parts_tm_button_focused"
        android:layout_width="304px"
        android:layout_height="56px"
        android:layout_marginLeft="168px"
        android:layout_marginTop="333px"
        android:text="@null"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center_horizontal"
        android:id="@+id/copy_theme_name"
        android:layout_width="304px"
        android:layout_height="56px"
        android:layout_marginLeft="168px"
        android:layout_marginTop="337px"
        android:text="@null"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_OFF"/>
    <ImageView
        android:id="@+id/up_arrow"
        android:background="@drawable/p_16_dd_parts_hgf_up_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="303px"
        android:layout_marginTop="313px"/>
    <ImageView
        android:id="@+id/down_arrow"
        android:background="@drawable/p_16_dd_parts_hgf_down_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="303px"
        android:layout_marginTop="391px"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/autofill_phone_suffix_re"
        base:guide_text_emt="@android:string/autofill_phone_suffix_re"/>
</RelativeLayout>
