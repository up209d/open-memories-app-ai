<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/hedder"
        android:background="@drawable/p_16_dd_parts_skyhdr_header"
        android:layout_width="640px"
        android:layout_height="66px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="0px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/menu_screen_title"
        android:layout_width="604px"
        android:layout_height="48px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="4px"
        android:text="@string/STRID_FUNC_DF_ISOAUTO_MINMAXG_L"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_FOCUSED"
        android:gravity="center"
        android:id="@+id/item_name"
        android:layout_width="484px"
        android:layout_height="44px"
        android:layout_marginLeft="78px"
        android:layout_marginTop="295px"
        android:text="@null"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <ImageView
        android:id="@+id/left_button"
        android:layout_width="247px"
        android:layout_height="62px"
        android:layout_marginLeft="73px"
        android:layout_marginTop="357px"
        android:src="@drawable/p_16_dd_parts_skyhdr_transparent_base"
        android:scaleType="fitXY"/>
    <ImageView
        android:id="@+id/right_button"
        android:layout_width="247px"
        android:layout_height="62px"
        android:layout_marginLeft="320px"
        android:layout_marginTop="357px"
        android:src="@drawable/p_16_dd_parts_skyhdr_transparent_base"
        android:scaleType="fitXY"/>
    <TextView
        android:typeface="4"
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/left_text"
        android:layout_width="247px"
        android:layout_height="46px"
        android:layout_marginLeft="73px"
        android:layout_marginTop="365px"
        android:text="ISO 100"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <TextView
        android:typeface="4"
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/right_text"
        android:layout_width="247px"
        android:layout_height="46px"
        android:layout_marginLeft="320px"
        android:layout_marginTop="365px"
        android:text="ISO 12800"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <ImageView
        android:id="@+id/left_up_arrow"
        android:background="@drawable/p_16_dd_parts_hgf_up_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="179px"
        android:layout_marginTop="350px"/>
    <ImageView
        android:id="@+id/left_down_arrow"
        android:background="@drawable/p_16_dd_parts_hgf_down_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="179px"
        android:layout_marginTop="408px"/>
    <ImageView
        android:id="@+id/right_up_arrow"
        android:background="@drawable/p_16_dd_parts_hgf_up_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="426px"
        android:layout_marginTop="350px"/>
    <ImageView
        android:id="@+id/right_down_arrow"
        android:background="@drawable/p_16_dd_parts_hgf_down_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="426px"
        android:layout_marginTop="408px"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/menu_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/autofill_phone_suffix_separator_re"
        base:guide_text_emt="@android:string/httpErrorAuth"/>
</RelativeLayout>
