<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.sony.imaging.app.digitalfilter.shooting.widget.GridLine
        android:id="@+id/gridline"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/menu_screen_title"
        android:layout_width="604px"
        android:layout_height="48px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="4px"
        android:text="Interval(Time, Shots, AE)"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <ImageView
        android:id="@+id/up_arrow1"
        android:background="@drawable/p_16_dd_parts_hgf_up_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="203px"
        android:layout_marginTop="350px"/>
    <ImageView
        android:id="@+id/down_arrow1"
        android:background="@drawable/p_16_dd_parts_hgf_down_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="203px"
        android:layout_marginTop="410px"/>
    <TextView
        android:gravity="center"
        android:id="@+id/interval_time"
        android:layout_width="74px"
        android:layout_height="42px"
        android:layout_marginLeft="183px"
        android:layout_marginTop="368px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <ImageView
        android:id="@+id/up_arrow2"
        android:background="@drawable/p_16_dd_parts_hgf_up_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="323px"
        android:layout_marginTop="350px"/>
    <ImageView
        android:id="@+id/down_arrow2"
        android:background="@drawable/p_16_dd_parts_hgf_down_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="323px"
        android:layout_marginTop="410px"/>
    <TextView
        android:gravity="center"
        android:id="@+id/interval_shots"
        android:layout_width="74px"
        android:layout_height="42px"
        android:layout_marginLeft="303px"
        android:layout_marginTop="368px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <ImageView
        android:id="@+id/up_arrow3"
        android:background="@drawable/p_16_dd_parts_hgf_up_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="491px"
        android:layout_marginTop="350px"/>
    <ImageView
        android:id="@+id/down_arrow3"
        android:background="@drawable/p_16_dd_parts_hgf_down_arrow_icon"
        android:layout_width="34px"
        android:layout_height="18px"
        android:layout_marginLeft="491px"
        android:layout_marginTop="410px"/>
    <TextView
        android:gravity="center"
        android:id="@+id/interval_ae"
        android:layout_width="151px"
        android:layout_height="42px"
        android:layout_marginLeft="433px"
        android:layout_marginTop="368px"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/transparent_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@string/STRID_FUNC_SKYND_GRADATION_DISABLEBAR_FOOTER"
        base:guide_text_emt="@string/STRID_FUNC_SKYND_GRADATION_DISABLEBAR_FOOTER"/>
</RelativeLayout>
