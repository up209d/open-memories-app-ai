    <string name="STRID_AMC_STR_01356">Snima sliku uz omjer širine i visine 3:2. Prikladno za uobičajeni tisak.</string>
    <string name="STRID_AMC_STR_01357">Snima sliku uz omjer širine i visine 16:9. Prikladno za pregledavanje na TV-u širokog zaslona.</string>
