<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/focusmag_icon"
        android:layout_width="40px"
        android:layout_height="36px"
        android:layout_marginLeft="2px"
        android:layout_marginTop="1px"
        android:src="@android:drawable/quickactions_arrowup_left_holo_dark"/>
    <com.sony.imaging.app.base.shooting.widget.MfAssistMagnificationRatio
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:id="@+id/magnification_ratio_view"
        android:background="@android:color/transparent"
        android:layout_width="110px"
        android:layout_height="36px"
        android:layout_marginLeft="42px"
        android:layout_marginTop="0px"
        style="@style/RESID_FONTSIZE_STD_M_EDGE_ON"/>
    <ImageView
        android:id="@+id/up_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="303px"
        android:layout_marginTop="2px"
        android:src="0x1080e0a"/>
    <ImageView
        android:id="@+id/down_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="303px"
        android:layout_marginTop="410px"
        android:src="0x1080e95"/>
    <ImageView
        android:id="@+id/left_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="2px"
        android:layout_marginTop="195px"
        android:src="0x108106f"/>
    <ImageView
        android:id="@+id/right_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="617px"
        android:layout_marginTop="195px"
        android:src="@android:drawable/ic_clear_material"/>
    <com.sony.imaging.app.base.shooting.widget.FocusMagnificationGuide
        android:id="@+id/magnification_position_view"
        android:layout_width="128px"
        android:layout_height="98px"
        android:layout_marginLeft="40px"
        android:layout_marginTop="314px"/>
    <com.sony.imaging.app.base.shooting.widget.FocusModeIcon
        android:id="@+id/magnification_focus_mode_icon"
        android:layout_width="70px"
        android:layout_height="60px"
        android:layout_marginLeft="570px"
        android:layout_marginTop="368px"
        base:af_a="0x1080f09"
        base:af_s="@android:drawable/tab_bottom_left"
        base:af_c="@android:drawable/switch_bg_disabled_holo_light"
        base:mf="0x1080ecf"
        base:dmf="@android:drawable/status_bar_item_app_background_normal"/>
    <com.sony.imaging.app.base.shooting.widget.MfAssistDistanceView
        android:id="@+id/magnification_distance"
        android:layout_width="288px"
        android:layout_height="62px"
        android:layout_marginLeft="185px"
        android:layout_marginTop="331px"/>
    <com.sony.imaging.app.base.common.widget.SteadyShotErrorIcon
        android:id="@+id/camera_shake_error"
        android:layout_width="76px"
        android:layout_height="36px"
        android:layout_marginLeft="340px"
        android:layout_marginTop="79px"/>
    <com.sony.imaging.app.base.common.widget.AbnormalTemperatureIcon
        android:id="@+id/abnormal_icon"
        android:layout_width="34px"
        android:layout_height="36px"
        android:layout_marginLeft="304px"
        android:layout_marginTop="79px"
        android:scaleType="center"
        base:heat="0x1080a4d"/>
    <com.sony.imaging.app.base.common.widget.DatabaseIcon
        android:id="@+id/DatabaseIcon"
        android:layout_width="60px"
        android:layout_height="36px"
        android:layout_marginLeft="242px"
        android:layout_marginTop="79px"
        android:scaleType="center"
        base:database_error="0x1080fef"
        base:database_full="@android:drawable/spinner_focused_holo_dark_am"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/focus_adjustment_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/keyguard_accessibility_slide_area"/>
</RelativeLayout>
