<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/background_icon"
        android:layout_width="556px"
        android:layout_height="480px"
        android:scaleType="fitXY"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"/>
    <com.sony.imaging.app.base.menu.layout.ExposureModeDialView
        android:id="@+id/SubMenuView"
        android:scrollbars="none"
        android:fadingEdge="none"
        android:layout_width="144px"
        android:layout_height="480px"
        android:cacheColorHint="#00000000"
        android:divider="#00000000"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:smoothScrollbar="true"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="center"
        android:id="@+id/mode_name"
        android:layout_width="484px"
        android:layout_height="46px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="top|left"
        android:id="@+id/guide_view"
        android:layout_width="484px"
        android:layout_height="272px"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:layout_width="640px"
        android:layout_height="60px"
        base:group="null"
        base:guide_text_style="@attr/footer_guide"
        base:guide_text_width="484px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/zen_mode_alarm"
        base:guide_text_emt="@android:string/zen_mode_alarm"/>
</RelativeLayout>
