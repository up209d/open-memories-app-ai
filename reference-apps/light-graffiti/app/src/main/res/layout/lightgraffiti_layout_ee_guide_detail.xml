<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/guide_background"
        android:background="@drawable/p_16_dd_parts_mle_guide_base"
        android:layout_width="600px"
        android:layout_height="416px"
        android:layout_marginLeft="20px"
        android:layout_marginTop="12px"
        android:scaleType="fitXY"/>
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="507px"
        android:layout_height="328px"
        android:layout_marginLeft="78px"
        android:layout_marginTop="60px"
        android:fadeScrollbars="false">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="484px"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/guide_header_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30px"
                android:src="@drawable/p_16_dd_parts_lightgraffiti_shooting_guide_1st_header_illust"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"/>
            <TextView
                android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
                android:id="@+id/guide_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30px"
                android:text="@string/STRID_FUNC_LIGHTGRAFFITI_GUIDE_CREATIVE_SHOOTING_1ST_W_APO_CAUTION"
                style="@style/RESID_FONTSIZE_M_EDGE"/>
            <ImageView
                android:id="@+id/guide_footer_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/p_16_dd_parts_lightgraffiti_shooting_guide_1st_footer_image"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"/>
        </LinearLayout>
    </ScrollView>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:background="0x1080a15"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:group="footer"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/years"
        base:guide_text_emt="@android:string/years"/>
</RelativeLayout>
