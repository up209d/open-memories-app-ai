	@Override
	protected int getLayout(int device, int dispmode) {
        int layout = -1;
        if(device == DisplayModeObserver.DEVICE_ID_PANEL) {
            layout = LAYOUT_LIST_FOR_PANEL.get(dispmode);
        } else if(device == DisplayModeObserver.DEVICE_ID_FINDER) {
            layout = LAYOUT_LIST_FOR_FINDER.get(dispmode);
        } else if(device == DisplayModeObserver.DEVICE_ID_HDMI) {
            layout = LAYOUT_LIST_FOR_HDMI.get(dispmode);
        }
		return layout;
	}

	private void setAntiBlurOff() {
        if (!ParametersModifier.ANTI_HAND_BLUR_MODE_OFF.equals(AntiHandBlurController.getInstance().getValue(AntiHandBlurController.STILL))) {
        	AntiHandBlurController.getInstance().setValue(AntiHandBlurController.STILL,
					ParametersModifier.ANTI_HAND_BLUR_MODE_OFF);
        }
	}

	private static String[] TAGS = new String[] {
		DisplayModeObserver.TAG_DEVICE_CHANGE,
		DisplayModeObserver.TAG_DISPMODE_CHANGE,
		DisplayModeObserver.TAG_YUVLAYOUT_CHANGE,
		GFConstants.MUTE_SCREEN
	};

	@Override
	public String[] getTags() {
		return TAGS;
	}

	@Override
	public void onNotify(String tag) {
		if (GFConstants.MUTE_SCREEN.equalsIgnoreCase(tag)) {
			muteOn();
		}
	}

	private void muteOn() {
		getView().setBackgroundColor(Color.BLACK);
	}
	private void muteOff() {
		getView().setBackgroundColor(0);
	}
}
