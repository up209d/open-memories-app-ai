	private static final String TAG = AppLog.getClassName();
	
	/**
	 * The LCD Panel's layouts
	 */
	protected static final SparseArray<Integer> LAYOUT_LIST_FOR_PANEL;
	/**
	 * The finder's layouts
	 */
	protected static final SparseArray<Integer> LAYOUT_LIST_FOR_FINDER;
	/**
	 * The hdmi's layouts
	 */
	protected static final SparseArray<Integer> LAYOUT_LIST_FOR_HDMI;
	
	static {
		LAYOUT_LIST_FOR_PANEL = new SparseArray<Integer>();
		LAYOUT_LIST_FOR_PANEL.append(DisplayModeObserver.DISPMODE_REC_INFO_ON, R.layout.shooting_main_sid_info_on_panel);
		LAYOUT_LIST_FOR_PANEL.append(GFDisplayModeObserver.DISPMODE_REC_APP_INFO_OFF, R.layout.shooting_main_sid_info_off_panel);
		LAYOUT_LIST_FOR_PANEL.append(DisplayModeObserver.DISPMODE_REC_INFO_OFF, R.layout.shooting_main_sid_info_off_panel);
		LAYOUT_LIST_FOR_PANEL.append(DisplayModeObserver.DISPMODE_REC_HISTOGRAM, R.layout.shooting_main_sid_histogram_panel);
		LAYOUT_LIST_FOR_PANEL.append(DisplayModeObserver.DISPMODE_REC_DIGITAL_LEVEL, R.layout.shooting_main_sid_digitallevel_panel);

		LAYOUT_LIST_FOR_FINDER = new SparseArray<Integer>();
		LAYOUT_LIST_FOR_FINDER.append(DisplayModeObserver.DISPMODE_REC_INFO_ON, R.layout.shooting_main_sid_basic_info_evf);
		LAYOUT_LIST_FOR_FINDER.append(GFDisplayModeObserver.DISPMODE_REC_APP_INFO_OFF, R.layout.shooting_main_sid_info_off_evf);
		LAYOUT_LIST_FOR_FINDER.append(DisplayModeObserver.DISPMODE_REC_INFO_OFF, R.layout.shooting_main_sid_info_off_evf);
		LAYOUT_LIST_FOR_FINDER.append(DisplayModeObserver.DISPMODE_REC_HISTOGRAM, R.layout.shooting_main_sid_histogram_evf);
		LAYOUT_LIST_FOR_FINDER.append(DisplayModeObserver.DISPMODE_REC_DIGITAL_LEVEL, R.layout.shooting_main_sid_digitallevel_evf);

		LAYOUT_LIST_FOR_HDMI = LAYOUT_LIST_FOR_PANEL;
	}
	
	

	@Override
	public void onResume() {
		super.onResume();
		muteOff();
		CameraNotificationManager.getInstance().setNotificationListener(this);
		GFDisplayModeObserver.getInstance().setNotificationListener(this);
		DisplayModeObserver.getInstance().setNotificationListener(this);
		setAntiBlurOff();
	}

	@Override
	public void onPause() {
		CameraNotificationManager.getInstance().removeNotificationListener(this);
		GFDisplayModeObserver.getInstance().removeNotificationListener(this);
		DisplayModeObserver.getInstance().removeNotificationListener(this);
		if ( !SaUtil.isAVIP() ){
			GFHistgramTask.getInstance().stopHistgramUpdating();
		}
		super.onPause();
	}


	@Override
	protected void createView() {
        int device = DisplayModeObserver.getInstance().getActiveDevice();
        int displayMode = GFDisplayModeObserver.getInstance().getActiveDispMode(DisplayModeObserver.APP_MODE_REC);

        int baseViewId = -1;
        int mainViewId = -1;
        int baseFooterViewId = -1;
        int touchAreaId = -1;
        
        if(device == DisplayModeObserver.DEVICE_ID_PANEL) {
            baseViewId = R.layout.shooting_base_sid_basic_info_panel;
            baseFooterViewId = R.layout.shooting_base_sid_basic_footer_panel;
            mainViewId = getLayout(device, displayMode);
            touchAreaId = R.id.touchArea;
        }
        else if(device == DisplayModeObserver.DEVICE_ID_FINDER) {
            baseViewId = R.layout.shooting_base_sid_basic_info_evf;
            baseFooterViewId = R.layout.shooting_base_sid_basic_footer_evf;
            mainViewId = getLayout(device, displayMode);
        }
        else if(device == DisplayModeObserver.DEVICE_ID_HDMI) {
            baseViewId = R.layout.shooting_base_sid_basic_info_panel;
            baseFooterViewId = R.layout.shooting_base_sid_basic_footer_panel;
            mainViewId = getLayout(device, displayMode);
            touchAreaId = R.id.touchArea; // HDMI出力時はタッチイベント自体が飛んでこないので消してOK
        }

        if ((-1 != baseViewId) && (-1 != baseFooterViewId) && (-1 != mainViewId) &&
			(baseViewId != mCurrentBaseViewId || baseFooterViewId != mCurrentBaseFooterViewId || mainViewId != mCurrentMainViewId)) {

			detachView();

			mCurrentBaseViewId = baseViewId;
            mCurrentMainViewId = mainViewId;
            mCurrentBaseFooterViewId = baseFooterViewId;
            mCurrentView = obtainViewFromPool(baseViewId);
            mCurrentBaseView = (ViewGroup)mCurrentView;
            
            View baseFooterView = mCurrentBaseFooterView = obtainViewFromPool(baseFooterViewId);
            mCurrentBaseView.addView(baseFooterView);
            if (null != baseFooterView) {
                mUserChangableViews[USER_CHANGING_APERTURE]          = (DigitView)baseFooterView.findViewById(R.id.aperture_view);
                mUserChangableViews[USER_CHANGING_SHUTTERSPEED]      = (DigitView)baseFooterView.findViewById(R.id.shutterspeed_view);
                mUserChangableViews[USER_CHANGING_EXPOSURE]          = (DigitView)baseFooterView.findViewById(R.id.exposure_and_meteredmanual_view);
                mUserChangableViews[USER_CHANGING_ISOSENSITIVITY]    = (DigitView)baseFooterView.findViewById(R.id.iso_sensitivity_view);
            }
            
			Looper.myQueue().addIdleHandler(idleHandler);
        }

		ExposureModeIconView icon1 = (ExposureModeIconView)mCurrentView.findViewById(R.id.i10_1);
		AppIconView icon2 = (AppIconView)mCurrentView.findViewById(R.id.app_icon);
        if (device == DisplayModeObserver.DEVICE_ID_FINDER) {
			icon1.setAutoDisappear(false);
			if (DisplayModeObserver.DISPMODE_REC_INFO_ON == displayMode) {
				icon2.setAutoDisappear(false);
			}
			else {
				icon2.setAutoDisappear(true);
			}
		}
		else {
			if (DisplayModeObserver.DISPMODE_REC_INFO_ON == displayMode) {
				icon1.setAutoDisappear(false);
				icon2.setAutoDisappear(false);
			}
			else {
				icon1.setAutoDisappear(true);
				icon2.setAutoDisappear(true);
			}
		}

        if(-1 != touchAreaId){
        	mTouchArea = (TouchArea)mCurrentView.findViewById(touchAreaId);
        	if(null != mTouchArea){
        		mTouchArea.setTouchAreaListener(getOnTouchListener());
        	}
        }
        handleGraduatedFilterIcon();
	}

