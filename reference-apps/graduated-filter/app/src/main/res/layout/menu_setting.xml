<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:base="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.sony.imaging.app.graduatedfilter.shooting.widget.BorderView
        android:id="@+id/border_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        base:border_mode="normal"
        base:setting="filter"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_NORMAL"
        android:gravity="left"
        android:id="@+id/menu_screen_title"
        android:layout_width="604px"
        android:layout_height="48px"
        android:layout_marginLeft="18px"
        android:layout_marginTop="4px"
        android:text="@string/STRID_FUNC_SKYND_SKYSETTINGS"
        style="@style/RESID_FONTSIZE_BIG_L_EDGE_ON"/>
    <com.sony.imaging.app.base.common.widget.BatteryIcon
        android:id="@+id/i10_2"
        android:layout_width="49px"
        android:layout_height="32px"
        android:layout_marginLeft="535px"
        android:layout_marginTop="2px"
        android:src="@drawable/icon_preend_battery"/>
    <include
        android:id="@+id/filter_info"
        layout="@layout/filter_info"/>
    <RelativeLayout
        android:id="@+id/iconBase00"
        android:background="0x10811bd"
        android:layout_width="190px"
        android:layout_height="66px"
        android:layout_marginLeft="122px"
        android:layout_marginTop="360px"/>
    <RelativeLayout
        android:id="@+id/iconBase01"
        android:background="0x10811bd"
        android:layout_width="190px"
        android:layout_height="66px"
        android:layout_marginLeft="328px"
        android:layout_marginTop="360px"/>
    <RelativeLayout
        android:id="@+id/separate00"
        android:background="@drawable/p_16_dd_parts_pe_parameter_separater"
        android:layout_width="2px"
        android:layout_height="66px"
        android:layout_marginLeft="216px"
        android:layout_marginTop="360px"/>
    <RelativeLayout
        android:id="@+id/separate01"
        android:background="@drawable/p_16_dd_parts_pe_parameter_separater"
        android:layout_width="2px"
        android:layout_height="66px"
        android:layout_marginLeft="422px"
        android:layout_marginTop="360px"/>
    <ImageView
        android:id="@+id/focus00"
        android:layout_width="94px"
        android:layout_height="66px"
        android:layout_marginLeft="122px"
        android:layout_marginTop="360px"/>
    <ImageView
        android:id="@+id/focus01"
        android:layout_width="94px"
        android:layout_height="66px"
        android:layout_marginLeft="218px"
        android:layout_marginTop="360px"/>
    <ImageView
        android:id="@+id/focus02"
        android:layout_width="94px"
        android:layout_height="66px"
        android:layout_marginLeft="328px"
        android:layout_marginTop="360px"/>
    <ImageView
        android:id="@+id/focus03"
        android:layout_width="94px"
        android:layout_height="66px"
        android:layout_marginLeft="424px"
        android:layout_marginTop="360px"/>
    <ImageView
        android:id="@+id/option00Image"
        android:layout_width="94px"
        android:layout_height="66px"
        android:layout_marginLeft="122px"
        android:layout_marginTop="360px"
        android:src="@drawable/p_16_dd_parts_hgf_position_icon"/>
    <ImageView
        android:id="@+id/option01Image"
        android:layout_width="94px"
        android:layout_height="66px"
        android:layout_marginLeft="218px"
        android:layout_marginTop="360px"
        android:src="@drawable/p_16_dd_parts_hgf_gradation_icon"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_CMN_WHITE_NO_SKIN"
        android:gravity="center"
        android:id="@+id/option01Value"
        android:layout_width="46px"
        android:layout_height="28px"
        android:layout_marginLeft="264px"
        android:layout_marginTop="380px"
        style="@style/RESID_FONTSIZE_S_EDGE"/>
    <ImageView
        android:id="@+id/option02Image"
        android:layout_width="94px"
        android:layout_height="66px"
        android:layout_marginLeft="328px"
        android:layout_marginTop="360px"
        android:src="@drawable/p_16_dd_parts_hgf_ev_icon"/>
    <ImageView
        android:id="@+id/option03Image"
        android:background="@drawable/p_16_dd_parts_hgf_wb_icon"
        android:layout_width="94px"
        android:layout_height="66px"
        android:layout_marginLeft="424px"
        android:layout_marginTop="360px"/>
    <TextView
        android:textColor="@color/RESID_FONTSTYLE_STD_FOCUSED"
        android:gravity="center"
        android:id="@+id/item_name"
        android:layout_width="484px"
        android:layout_height="44px"
        android:layout_marginLeft="78px"
        android:layout_marginTop="313px"
        android:text="@null"
        style="@style/RESID_FONTSIZE_BIG_M_EDGE_ON"/>
    <com.sony.imaging.app.base.common.widget.FooterGuide
        android:id="@+id/footer_guide"
        android:layout_width="640px"
        android:layout_height="60px"
        android:layout_marginLeft="0px"
        android:layout_marginTop="420px"
        base:guide_text_style="@attr/transparent_footer_guide"
        base:guide_text_marginLeft="8px"
        base:guide_text_marginTop="12px"
        base:guide_text_width="624px"
        base:guide_text_height="40px"
        base:guide_text_p1="@android:string/years"
        base:guide_text_emt="@android:string/years"/>
</RelativeLayout>
