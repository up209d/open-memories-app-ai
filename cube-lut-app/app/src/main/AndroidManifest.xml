<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.github.up209d.cubelut" >

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application android:label="@string/app_name" >
        <receiver android:name=".ExitCompletedReceiver" >
            <intent-filter>
                <action android:name="com.android.server.DAConnectionManagerService.ExitCompleted" />
                <category android:name="ANDROID.INTENT.CATEGORY.DEFAULT" />
            </intent-filter>
        </receiver>
        <receiver android:name=".BootCompletedReceiver" >
            <intent-filter>
                <action android:name="com.android.server.DAConnectionManagerService.BootCompleted" />
                <category android:name="ANDROID.INTENT.CATEGORY.DEFAULT" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".CubeLutApp"
            android:label="@string/app_name" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".LutMenuActivity"
            android:label="@string/title_lut_browser" >
        </activity>
        <activity
            android:name=".HelpActivity"
            android:label="@string/title_help" >
        </activity>
    </application>

</manifest>
